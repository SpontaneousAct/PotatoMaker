---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "PotatoMaker",
  description = "Turn large video recordings into smaller MP4 clips that are easier to share."
} = Astro.props;

const assetBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:FILL@1&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href={`${assetBase}potato.ico`} sizes="any" />
  </head>
  <body class="min-h-screen bg-[radial-gradient(circle_at_top,_rgba(204,140,68,0.2),_transparent_30%),linear-gradient(180deg,_#26211d_0%,_#141110_55%,_#0e0b0a_100%)] text-stone-100">
    <slot />
  </body>
</html>
