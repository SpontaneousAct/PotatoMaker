---
import BaseLayout from "../layouts/BaseLayout.astro";

const homeHref = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const githubUrl = "https://github.com/SpontaneousAct/PotatoMaker";
const privacyUrl = `${homeHref}privacy/`;
const latestSetupUrl =
  "https://github.com/SpontaneousAct/PotatoMaker/releases/latest/download/PotatoMaker-win-x64-Setup.exe";

const quickStartSteps = [
  "Open a supported video with Browse or drag and drop (you can also use the recent videos list).",
  "Trim the part you want with drag controls or the start/end buttons.",
  "Pick an output folder if you do not want to save next to the source file.",
  "Click Compress.",
  "That's it! The app will choose a good resolution and bitrate for you, and split into parts if needed."
];

const sections = [
  {
    id: "main-screen",
    title: "Main screen",
    items: [
      "File input lets you browse for a file or drag one into the app.",
      "The player is used for previewing and choosing trim points.",
      "Selected Clip shows the current start, end, and duration. Below you can see the planned resolution, bitrate, parts, crop mode, and FPS.",
      "PotatoMaker automatically detects pillarbox and applies cropping if needed.",
      "Conversion log shows whether the app is analyzing, ready, compressing, or done."
    ]
  },
  {
    id: "queue-and-recent",
    title: "Queue and recent videos",
    items: [
      "Add to queue saves the current selection without starting right away. Start time, end time, crop and FPS settings are preserved.", 
      "You can add multiple clips from the same video with different settings.",
      "The queue runs items one after another and can persist between sessions.",
      "Recent videos shows supported files from the configured folder for quick opening."
    ]
  },
  {
    id: "settings",
    title: "Settings",
    items: [
      "Choose the app theme.",
      "Set the folder used by Recent videos.",
      "Prefer NVIDIA NVENC AV1 when available.",
      "Change the CPU preset for the SVT-AV1 path.",
      "Set output filename prefix and suffix."
    ]
  }
];

const shortcuts = [
  { key: "Space", meaning: "Play or pause." },
  { key: "Q", meaning: "Jump back 10 seconds." },
  { key: "E", meaning: "Jump forward 10 seconds." },
  { key: "A", meaning: "Set trim start." },
  { key: "D", meaning: "Set trim end." }
];

const troubleshooting = [
  "If Compress is unavailable, wait for analysis to finish.",
  "If Strategy Preview shows multiple parts, the export will be split into several MP4 files.",
  "If NVENC AV1 is unavailable, use the CPU path instead.",
  "If no custom output folder is selected, files are written next to the source video.",
  "If the app crashes, copy the crash report after restart and include it in a GitHub issue."
];
---

<BaseLayout
  title="PotatoMaker Help"
  description="Simple help and usage guide for PotatoMaker."
>
  <main class="mx-auto min-h-screen w-full max-w-4xl px-5 py-6 sm:px-8 lg:px-10">
    <header class="flex flex-wrap items-center justify-between gap-4 border-b border-[#3b322b] pb-5">
      <a class="text-sm text-stone-300 hover:text-white" href={homeHref}>Back</a>
    </header>

    <section class="space-y-4 py-8">
      <h1 class="text-3xl font-semibold text-white sm:text-4xl">PotatoMaker guide</h1>
      <p class="max-w-3xl text-base leading-7 text-stone-300">
        PotatoMaker helps you turn any video into a smaller MP4 that is easy to share.
        Open a file, trim the part you want, compress.
      </p>
      <p class="text-base leading-7 text-stone-400">
        <a class="ml-2 text-[#d7af81] hover:text-white" href="#quick-start">Quick start</a>
        <a class="ml-3 text-[#d7af81] hover:text-white" href="#main-screen">Main screen</a>
        <a class="ml-3 text-[#d7af81] hover:text-white" href="#settings">Settings</a>
        <a class="ml-3 text-[#d7af81] hover:text-white" href="#shortcuts">Shortcuts</a>
        <a class="ml-3 text-[#d7af81] hover:text-white" href="#troubleshooting">Troubleshooting</a>
      </p>
    </section>

    <section id="quick-start" class="border-t border-[#332b25] py-8">
      <h2 class="text-xl font-semibold text-white">Quick start</h2>
      <ol class="mt-4 space-y-3 pl-5 text-base leading-7 text-stone-300 list-decimal">
        {quickStartSteps.map((step) => <li>{step}</li>)}
      </ol>
    </section>

    {sections.map((section) => (
      <section id={section.id} class="border-t border-[#332b25] py-8">
        <h2 class="text-xl font-semibold text-white">{section.title}</h2>
        <ul class="mt-4 space-y-3 pl-5 text-base leading-7 text-stone-300 list-disc">
          {section.items.map((item) => <li>{item}</li>)}
        </ul>
      </section>
    ))}

    <section id="shortcuts" class="border-t border-[#332b25] py-8">
      <h2 class="text-xl font-semibold text-white">Keyboard shortcuts</h2>
      <p class="mt-3 text-base leading-7 text-stone-300">Useful for trimming without reaching for buttons.</p>

      <div class="mt-4 overflow-hidden border border-[#40352d]">
        <table class="w-full border-collapse text-left text-base text-stone-300">
          <thead class="bg-[#1f1916] text-stone-200">
            <tr>
              <th class="px-4 py-3 font-semibold">Key</th>
              <th class="px-4 py-3 font-semibold">Action</th>
            </tr>
          </thead>
          <tbody>
            {shortcuts.map((shortcut) => (
              <tr class="border-t border-[#302823]">
                <td class="px-4 py-3 font-semibold text-white">{shortcut.key}</td>
                <td class="px-4 py-3">{shortcut.meaning}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section id="troubleshooting" class="border-t border-[#332b25] py-8">
      <h2 class="text-xl font-semibold text-white">Troubleshooting</h2>
      <ul class="mt-4 space-y-3 pl-5 text-base leading-7 text-stone-300 list-disc">
        {troubleshooting.map((item) => <li>{item}</li>)}
      </ul>
      <p class="mt-4 text-base leading-7 text-stone-300">
        Need more help?
        <a class="text-[#d7af81] hover:text-white" href={githubUrl + "/issues/new"}>Open a GitHub issue</a>.
      </p>
    </section>
  </main>
</BaseLayout>
