---
import BaseLayout from "../layouts/BaseLayout.astro";

const homeHref = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const helpUrl = `${homeHref}help/`;
const githubUrl = "https://github.com/SpontaneousAct/PotatoMaker";
---

<BaseLayout
  title="PotatoMaker | Privacy Policy"
  description="Privacy policy for the PotatoMaker website and app."
>
  <main class="mx-auto min-h-screen w-full max-w-4xl px-5 py-6 sm:px-8 lg:px-10">
    <header class="flex flex-wrap items-center justify-between gap-4 border-b border-[#3b322b] pb-5">
      <a class="text-sm text-stone-300 hover:text-white" href={homeHref}>Back</a>
    </header>

    <section class="space-y-5 py-8">
      <div class="space-y-2">
        <p class="text-sm font-medium uppercase tracking-[0.26em] text-[#d7af81]">Privacy Policy</p>
      </div>

      <div class="max-w-3xl space-y-6 text-base leading-7 text-stone-300">
        <p>
          PotatoMaker does not collect personal data, analytics, telemetry, or videos.
        </p>

        <section class="space-y-3">
          <h2 class="text-xl font-semibold text-white">No accounts or tracking</h2>
          <ul class="space-y-2">
            <li>No user accounts</li>
            <li>No analytics</li>
            <li>No in-app telemetry</li>
            <li>No video uploads or cloud processing</li>
          </ul>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-semibold text-white">GitHub services</h2>
          <p>
            The website uses GitHub Pages and downloads use GitHub Releases. GitHub may record standard
            request data or use cookies when you visit or download the app. See the
            <a
              class="text-[#d7af81] hover:text-white"
              href="https://docs.github.com/en/site-policy/privacy-policies/github-privacy-statement"
            >
              GitHub Privacy Statement
            </a>.
          </p>
        </section>
      </div>
    </section>
  </main>
</BaseLayout>
