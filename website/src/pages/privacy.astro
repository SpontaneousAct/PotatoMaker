---
import BaseLayout from "../layouts/BaseLayout.astro";

const homeHref = import.meta.env.BASE_URL;
---

<BaseLayout
  title="PotatoMaker | Privacy Policy"
  description="Privacy policy for the PotatoMaker website and app."
>
  <main class="mx-auto min-h-screen w-full max-w-4xl px-5 py-6 sm:px-8 lg:px-10">
    <header class="border-b border-[#3b322b] pb-5">
      <a class="text-sm text-stone-300 hover:text-white" href={homeHref}>Back to home</a>
    </header>

    <section class="space-y-5 py-8">
      <div class="space-y-2">
        <p class="text-sm font-medium uppercase tracking-[0.26em] text-[#d7af81]">Privacy Policy</p>
      </div>

      <div class="max-w-3xl space-y-6 text-base leading-7 text-stone-300">
        <p>
          This website does not ask you to create an account, submit personal information, or sign in
          to use it.
          The PotatoMaker app also does not collect, store, or send personal data, analytics, or
          telemetry.
        </p>

        <section class="space-y-3">
          <h2 class="text-xl font-semibold text-white">What PotatoMaker does not collect</h2>
          <ul class="space-y-2">
            <li>No user accounts</li>
            <li>No analytics</li>
            <li>No advertising trackers</li>
            <li>No marketing cookies set by this site</li>
            <li>No in-app telemetry</li>
            <li>No uploaded videos or cloud processing</li>
          </ul>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-semibold text-white">Hosting and downloads</h2>
          <p>
            This website is hosted on GitHub Pages, and downloads are provided through GitHub Releases.
            That means GitHub may receive routine technical information when you visit the site or
            download a release, such as your IP address, browser details, request metadata, and other
            standard server or platform logs.
          </p>
          <p>
            PotatoMaker does not control GitHub's infrastructure or GitHub's handling of that data.
            For more information, see the
            <a
              class="text-[#d7af81] hover:text-white"
              href="https://docs.github.com/en/site-policy/privacy-policies/github-privacy-statement"
            >
              GitHub Privacy Statement
            </a>.
          </p>
        </section>

        <section class="space-y-3">
          <h2 class="text-xl font-semibold text-white">Cookies</h2>
          <p>
            This website does not intentionally set its own analytics, advertising, or marketing
            cookies. However, GitHub may use cookies or similar technologies as part of providing
            GitHub Pages, GitHub Releases, and related platform functionality.
          </p>
        </section>

<hr class="border-0 h-px bg-stone-700">
        <section class="space-y-3">
          <p>
            This policy may be updated if the website or app changes in a way that affects privacy.
            Any updated version will be posted on this page.
          </p>
        </section>
      </div>
    </section>
  </main>
</BaseLayout>
