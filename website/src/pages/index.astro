---
import BaseLayout from "../layouts/BaseLayout.astro";

const workflowLoopDuration = 20;

const steps = [
  {
    title: "Open",
    description: "Drop in a clip or choose one from the latest videos.",
    start: 0,
    end: 3
  },
  {
    title: "Trim",
    description: "Grab only the part you want.",
    start: 3,
    end: 12
  },
  {
    title: "Compress",
    description: "Export a file that will always be under 10 MB.",
    start: 12,
    end: workflowLoopDuration
  }
];

const capabilities = [
  {
    title: "Trim the part you actually want",
    description: "Cut straight to the highlight instead of exporting the whole recording.",
    icon: "content_cut"
  },
  {
    title: "Queue up multiple clips",
    description: "Line up a few exports and let them run without babysitting each one.",
    icon: "queue_play_next"
  },
  {
    title: "Adjust crop and FPS",
    description: "Tighten framing or lower frame rate when the raw capture is bigger than it needs to be.",
    icon: "tune"
  },
  {
    title: "Auto-detect crop for ultrawide",
    description: "Works with ultrawide and super ultrawide footage so empty space does not waste size.",
    icon: "crop"
  },
  {
    title: "Built-in auto-updates",
    description: "Keeps the desktop app current without making updates a chore.",
    icon: "system_update_alt"
  },
  {
    title: "Recent videos ready to pick",
    description: "Jump back into your latest saved captures without digging through folders.",
    icon: "video_library"
  }
];

const homeHref = import.meta.env.BASE_URL;
const githubUrl = "https://github.com/SpontaneousAct/PotatoMaker";
const iconUrl = `${homeHref}potato.ico`;
const screenshotUrl = `${homeHref}images/app-screenshot.png`;
const previewVideoUrl = `${homeHref}images/preview.mp4`;
const helpUrl = `${homeHref}help/`;
const privacyUrl = `${homeHref}privacy/`;
const latestSetupUrl =
  "https://github.com/SpontaneousAct/PotatoMaker/releases/latest/download/PotatoMaker-win-x64-Setup.exe";
const copyrightYear = new Date().getFullYear();
const workflowDuration = workflowLoopDuration;
---

<BaseLayout
  title="PotatoMaker | Compress any video to under 10 MB"
  description="PotatoMaker helps you trim and compress videos into smaller shareable MP4 clips without manual FFmpeg tuning."
>
  <main id="home" class="mx-auto min-h-screen w-full max-w-6xl px-5 py-6 sm:px-8 lg:px-10">
    <div class="grid min-h-screen grid-rows-[auto_1fr]">
      <header class="flex items-center justify-between gap-4 border-b border-[#3b322b] pb-5">
        <a class="flex items-center gap-3 text-white" href={homeHref}>
          <img alt="PotatoMaker icon" class="h-8 w-8 rounded-md" src={iconUrl} />
          <span class="text-lg font-semibold tracking-tight">PotatoMaker</span>
        </a>
        <nav class="flex flex-wrap items-center gap-3">
          <a
            class="rounded-full border border-[#4c4036] px-4 py-2 text-sm text-stone-200 hover:border-[#8f6232] hover:text-white"
            href={helpUrl}
          >
            Help
          </a>
          <a
            class="rounded-full border border-[#4c4036] px-4 py-2 text-sm text-stone-200 hover:border-[#8f6232] hover:text-white"
            href={githubUrl}
          >
            GitHub
          </a>
        </nav>
      </header>

      <section class="grid items-center gap-10 py-8 lg:-translate-y-5 lg:grid-cols-[1fr_0.95fr] lg:gap-14 lg:py-8">
        <div class="space-y-8">
          <div class="space-y-5">
            <h1 class="max-w-3xl text-4xl font-semibold tracking-tight text-white sm:text-5xl lg:text-6xl">
              Compress any video to under <br /> 10 MB.
            </h1>
            <p class="max-w-2xl text-base leading-7 text-stone-300 sm:text-lg">
              Open a video, trim the part you want, and let PotatoMaker choose a practical export
              strategy.
            </p>
          </div>

          <div class="flex flex-wrap gap-3">
            <a
              class="rounded-full bg-[#a36b33] px-5 py-3 font-medium text-white hover:bg-[#b97a3c]"
              href={latestSetupUrl}
            >
              Download for Windows
            </a>
            <a
              class="rounded-full border border-[#4c4036] px-5 py-3 font-medium text-white hover:border-[#8f6232]"
              href=#learn-more
            >
              Learn more
            </a>
          </div>
        </div>

        <div class="hero-image-shell">
          <img
            alt="PotatoMaker app screenshot"
            class="hero-image w-full rounded-[0.2rem] border-1 border-[#5a4a3d] bg-[#2c241d]"
            src={screenshotUrl}
          />
        </div>
      </section>
    </div>

    <section
      id="learn-more"
      class="grid min-h-screen grid-rows-[auto_1fr] border-t border-[#332b25] py-10"
    >
      <div class="space-y-2">
        <p class="text-sm font-medium uppercase tracking-[0.26em] text-[#d7af81]">Workflow</p>
        <h2 class="text-2xl font-semibold text-white sm:text-3xl">Built for quickly sharing clips</h2>
      </div>

      <div class="grid items-center">
        <div class="grid gap-5 lg:grid-cols-[minmax(0,1.38fr)_minmax(16rem,21rem)] lg:items-center lg:justify-between">
          <div
            class="w-full"
            data-workflow-demo
            data-workflow-duration={workflowDuration}
          >
            <div class="overflow-hidden rounded-[0.3rem]">
              <video
                aria-label="PotatoMaker workflow preview showing opening a file, trimming, and compressing"
                autoplay
                data-workflow-media
                height="752"
                loop
                muted
                playsinline
                preload="auto"
                width="1280"
                class="h-auto w-full"
              >
                <source src={previewVideoUrl} type="video/mp4" />
              </video>
            </div>
          </div>

          <div class="grid gap-2.5 lg:justify-self-end">
            {steps.map((step, index) => (
              <article
                class="workflow-step rounded-[0.8rem] border border-[#43382f] bg-[#1b1714] px-3.5 py-2.5 sm:px-4 sm:py-3"
                data-workflow-step
                data-start={step.start}
                data-end={step.end}
                data-active={index === 0 ? "true" : "false"}
              >
                <h3 class="text-[1.05rem] font-semibold text-white sm:text-[1.3rem]">{step.title}</h3>
                <p class="mt-1 text-[0.92rem] leading-5 text-stone-300">{step.description}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="border-t border-[#332b25] py-16">
      <div class="space-y-8">
        <div class="max-w-2xl space-y-3">
          <h2 class="text-2xl font-semibold text-white sm:text-3xl">Everything you need to make a clip fit</h2>
          <p class="text-sm leading-7 text-stone-300 sm:text-base">
            The basics are built in, so you can go from raw capture to something postable without a lot of fiddling.
          </p>
        </div>

        <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
          {capabilities.map((item) => (
            <article class="flex min-h-[148px] items-center rounded-[1.25rem] border border-[#43382f] bg-[#1b1714] px-5 py-4">
              <div class="flex items-center gap-3">
                <div class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-[0.85rem] bg-[#211b18] text-[#efc594]">
                  <span aria-hidden="true" class="material-symbols-rounded">{item.icon}</span>
                </div>
                <div class="min-w-0">
                  <h3 class="text-[15px] font-semibold leading-6 text-white">{item.title}</h3>
                  <p class="mt-1 text-sm leading-6 text-stone-300">{item.description}</p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="border-t border-[#332b25] py-8">
      <footer class="w-full">
        <div class="flex flex-col gap-6 rounded-[1.75rem] border border-[#43382f] bg-[#171311]/90 px-6 py-6 sm:px-8 lg:flex-row lg:items-center lg:justify-between">
          <p class="text-sm text-stone-500">Copyright (c) {copyrightYear} SpontaneousAct</p>
          <nav class="flex flex-wrap gap-x-6 gap-y-3 text-sm text-stone-300">
            <a class="hover:text-white" href="#home">Home</a>
            <a class="hover:text-white" href={helpUrl}>Help</a>
            <a class="hover:text-white" href={privacyUrl}>Privacy policy</a>
            <a class="hover:text-white" href={githubUrl}>Source code</a>
          </nav>
        </div>
      </footer>
    </section>
  </main>
</BaseLayout>

<script>
  const workflowRoots = document.querySelectorAll("[data-workflow-demo]");

  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  const clamp = (value, min, max) => Math.min(Math.max(value, min), max);

  const setActiveStep = (steps, progressBar, currentTime, duration) => {
    const normalizedTime = duration > 0 ? currentTime % duration : 0;

    steps.forEach((step, index) => {
      const start = Number(step.dataset.start ?? 0);
      const end = Number(step.dataset.end ?? duration);
      const isLastStep = index === steps.length - 1;
      const isActive = normalizedTime >= start && (normalizedTime < end || (isLastStep && normalizedTime <= end));

      step.dataset.active = isActive ? "true" : "false";
    });

    if (progressBar) {
      const progress = duration > 0 ? clamp(normalizedTime / duration, 0, 1) : 0;
      progressBar.style.width = `${progress * 100}%`;
    }
  };

  workflowRoots.forEach((root) => {
    const duration = Number(root.dataset.workflowDuration ?? root.dataset.duration ?? 0);
    const section = root.closest("section");
    const steps = Array.from(section?.querySelectorAll("[data-workflow-step]") ?? []);
    const progressBar = root.querySelector("[data-workflow-progress]");
    const media = root.querySelector("[data-workflow-media]");

    if (steps.length === 0 || duration <= 0) {
      return;
    }

    if (prefersReducedMotion.matches) {
      setActiveStep(steps, progressBar, 0, duration);
      return;
    }

    if (media instanceof HTMLVideoElement) {
      const syncFromVideo = () => {
        const videoDuration = Number.isFinite(media.duration) && media.duration > 0 ? media.duration : duration;
        setActiveStep(steps, progressBar, media.currentTime, videoDuration);
      };

      media.addEventListener("timeupdate", syncFromVideo);
      media.addEventListener("play", syncFromVideo);
      media.addEventListener("seeked", syncFromVideo);
      media.addEventListener("loadedmetadata", syncFromVideo);
      syncFromVideo();
      return;
    }

    let loopStart = performance.now();
    let animationFrame = 0;

    const resetLoop = () => {
      loopStart = performance.now();
    };

    const tick = (now) => {
      setActiveStep(steps, progressBar, (now - loopStart) / 1000, duration);
      animationFrame = window.requestAnimationFrame(tick);
    };

    if (media instanceof HTMLImageElement) {
      if (media.complete) {
        resetLoop();
      } else {
        media.addEventListener("load", resetLoop, { once: true });
      }
    }

    document.addEventListener("visibilitychange", () => {
      if (document.visibilityState === "visible") {
        resetLoop();
      }
    });

    animationFrame = window.requestAnimationFrame(tick);

    window.addEventListener(
      "beforeunload",
      () => {
        window.cancelAnimationFrame(animationFrame);
      },
      { once: true }
    );
  });
</script>
