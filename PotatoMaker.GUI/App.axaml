<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PotatoMaker.GUI.ViewModels"
             xmlns:views="using:PotatoMaker.GUI.Views"
             x:Class="PotatoMaker.GUI.App"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <DataTemplate DataType="vm:FileInputViewModel">
            <views:FileInputView/>
        </DataTemplate>
        <DataTemplate DataType="vm:VideoSummaryViewModel">
            <views:VideoSummaryView/>
        </DataTemplate>
        <DataTemplate DataType="vm:OutputSettingsViewModel">
            <views:OutputSettingsView/>
        </DataTemplate>
        <DataTemplate DataType="vm:ConversionLogViewModel">
            <views:ConversionLogView/>
        </DataTemplate>
        <DataTemplate DataType="vm:HelpModalViewModel">
            <views:HelpModalView/>
        </DataTemplate>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="PmWindowBackground">#FFF2F4F8</SolidColorBrush>
                    <SolidColorBrush x:Key="PmCardBackground">#FFFFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="PmCardBorderBrush">#FFD7DCE5</SolidColorBrush>
                    <LinearGradientBrush x:Key="PmHeroBackground" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFEAF1FA" Offset="0"/>
                        <GradientStop Color="#FFDEE8F5" Offset="1"/>
                    </LinearGradientBrush>
                    <SolidColorBrush x:Key="PmHeroBorderBrush">#FFC8D7EA</SolidColorBrush>
                    <SolidColorBrush x:Key="PmHeadingForeground">#FF151D2B</SolidColorBrush>
                    <SolidColorBrush x:Key="PmSectionTitleForeground">#FF223045</SolidColorBrush>
                    <SolidColorBrush x:Key="PmMutedForeground">#FF5A667B</SolidColorBrush>

                    <SolidColorBrush x:Key="PmPrimaryBackground">#FF176FE5</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPrimaryPointerOver">#FF267BEF</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPrimaryPressed">#FF0E5EC8</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPrimaryBorder">#FF3A86EA</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPrimaryDisabledBackground">#FFE4E8EF</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPrimaryDisabledBorder">#FFD3D9E4</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPrimaryDisabledForeground">#FF7A8699</SolidColorBrush>
                    <SolidColorBrush x:Key="PmCancelBackground">#FFD24B4B</SolidColorBrush>
                    <SolidColorBrush x:Key="PmCancelPointerOver">#FFDF5B5B</SolidColorBrush>
                    <SolidColorBrush x:Key="PmCancelPressed">#FFB63F3F</SolidColorBrush>
                    <SolidColorBrush x:Key="PmCancelBorder">#FFCC6A6A</SolidColorBrush>

                    <SolidColorBrush x:Key="PmDropzoneBackground">#FFF6F9FD</SolidColorBrush>
                    <SolidColorBrush x:Key="PmDropzoneBorderBrush">#FFB4C3D8</SolidColorBrush>
                    <SolidColorBrush x:Key="PmDropzoneDragBackground">#FFE9F1FB</SolidColorBrush>
                    <SolidColorBrush x:Key="PmDropzoneDragBorderBrush">#FF4E7EB8</SolidColorBrush>

                    <SolidColorBrush x:Key="PmStatBackground">#FFF6F8FB</SolidColorBrush>
                    <SolidColorBrush x:Key="PmStatBorderBrush">#FFD6DEE9</SolidColorBrush>
                    <SolidColorBrush x:Key="PmInsetBackground">#FFF4F7FB</SolidColorBrush>
                    <SolidColorBrush x:Key="PmInsetBorderBrush">#FFD6DEE8</SolidColorBrush>
                    <SolidColorBrush x:Key="PmVideoSurfaceBackground">#FF0B0E14</SolidColorBrush>
                    <SolidColorBrush x:Key="PmVideoSurfaceBorderBrush">#FF2B3340</SolidColorBrush>
                    <SolidColorBrush x:Key="PmErrorForeground">#FFBC3030</SolidColorBrush>
                </ResourceDictionary>

                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="PmWindowBackground">#FF0E1116</SolidColorBrush>
                    <SolidColorBrush x:Key="PmCardBackground">#FF1A202A</SolidColorBrush>
                    <SolidColorBrush x:Key="PmCardBorderBrush">#FF2A3342</SolidColorBrush>
                    <LinearGradientBrush x:Key="PmHeroBackground" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF243448" Offset="0"/>
                        <GradientStop Color="#FF161E29" Offset="1"/>
                    </LinearGradientBrush>
                    <SolidColorBrush x:Key="PmHeroBorderBrush">#FF3A4D67</SolidColorBrush>
                    <SolidColorBrush x:Key="PmHeadingForeground">#FFF2F7FF</SolidColorBrush>
                    <SolidColorBrush x:Key="PmSectionTitleForeground">#FFE7EDF7</SolidColorBrush>
                    <SolidColorBrush x:Key="PmMutedForeground">#FFD3DCEC</SolidColorBrush>

                    <SolidColorBrush x:Key="PmPrimaryBackground">#FF3A7AFE</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPrimaryPointerOver">#FF4A86FF</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPrimaryPressed">#FF2A68E8</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPrimaryBorder">#FF5A91FF</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPrimaryDisabledBackground">#FF2A3342</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPrimaryDisabledBorder">#FF2A3342</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPrimaryDisabledForeground">#FF98A6BB</SolidColorBrush>
                    <SolidColorBrush x:Key="PmCancelBackground">#FFC65252</SolidColorBrush>
                    <SolidColorBrush x:Key="PmCancelPointerOver">#FFD26262</SolidColorBrush>
                    <SolidColorBrush x:Key="PmCancelPressed">#FFAA4747</SolidColorBrush>
                    <SolidColorBrush x:Key="PmCancelBorder">#FFD07878</SolidColorBrush>

                    <SolidColorBrush x:Key="PmDropzoneBackground">#FF151B25</SolidColorBrush>
                    <SolidColorBrush x:Key="PmDropzoneBorderBrush">#FF41506A</SolidColorBrush>
                    <SolidColorBrush x:Key="PmDropzoneDragBackground">#FF1E2A3A</SolidColorBrush>
                    <SolidColorBrush x:Key="PmDropzoneDragBorderBrush">#FF5F95FF</SolidColorBrush>

                    <SolidColorBrush x:Key="PmStatBackground">#FF121821</SolidColorBrush>
                    <SolidColorBrush x:Key="PmStatBorderBrush">#FF273143</SolidColorBrush>
                    <SolidColorBrush x:Key="PmInsetBackground">#FF0F141C</SolidColorBrush>
                    <SolidColorBrush x:Key="PmInsetBorderBrush">#FF273143</SolidColorBrush>
                    <SolidColorBrush x:Key="PmVideoSurfaceBackground">#FF05070B</SolidColorBrush>
                    <SolidColorBrush x:Key="PmVideoSurfaceBorderBrush">#FF2A3342</SolidColorBrush>
                    <SolidColorBrush x:Key="PmErrorForeground">#FFFF8E8E</SolidColorBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <Style Selector="Window">
            <Setter Property="Background" Value="{DynamicResource PmWindowBackground}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style Selector="Border.pm-card">
            <Setter Property="Background" Value="{DynamicResource PmCardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmCardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>

        <Style Selector="Border.pm-hero">
            <Setter Property="Background" Value="{DynamicResource PmHeroBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmHeroBorderBrush}"/>
        </Style>

        <Style Selector="Border.pm-inset">
            <Setter Property="Background" Value="{DynamicResource PmInsetBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmInsetBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style Selector="Border.pm-video-surface">
            <Setter Property="Background" Value="{DynamicResource PmVideoSurfaceBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmVideoSurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>

        <Style Selector="TextBlock.pm-heading">
            <Setter Property="FontFamily" Value="Bahnschrift,Segoe UI Semibold"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="{DynamicResource PmHeadingForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-section-title">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource PmSectionTitleForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-muted">
            <Setter Property="Opacity" Value="0.82"/>
            <Setter Property="Foreground" Value="{DynamicResource PmMutedForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-caption">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Opacity" Value="0.82"/>
            <Setter Property="Foreground" Value="{DynamicResource PmMutedForeground}"/>
        </Style>

        <Style Selector="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="30"/>
        </Style>

        <Style Selector="Button.pm-primary">
            <Setter Property="Background" Value="{DynamicResource PmPrimaryBackground}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmPrimaryBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style Selector="Button.pm-primary:pointerover">
            <Setter Property="Background" Value="{DynamicResource PmPrimaryPointerOver}"/>
        </Style>

        <Style Selector="Button.pm-primary:pressed">
            <Setter Property="Background" Value="{DynamicResource PmPrimaryPressed}"/>
        </Style>

        <Style Selector="Button.pm-primary:disabled">
            <Setter Property="Background" Value="{DynamicResource PmPrimaryDisabledBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmPrimaryDisabledBorder}"/>
            <Setter Property="Foreground" Value="{DynamicResource PmPrimaryDisabledForeground}"/>
        </Style>

        <Style Selector="Button.pm-cancel">
            <Setter Property="Background" Value="{DynamicResource PmCancelBackground}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmCancelBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style Selector="Button.pm-cancel:pointerover">
            <Setter Property="Background" Value="{DynamicResource PmCancelPointerOver}"/>
        </Style>

        <Style Selector="Button.pm-cancel:pressed">
            <Setter Property="Background" Value="{DynamicResource PmCancelPressed}"/>
        </Style>

        <Style Selector="Button.pm-cancel:disabled">
            <Setter Property="Background" Value="{DynamicResource PmPrimaryDisabledBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmPrimaryDisabledBorder}"/>
            <Setter Property="Foreground" Value="{DynamicResource PmPrimaryDisabledForeground}"/>
        </Style>

        <Style Selector="Border.pm-dropzone">
            <Setter Property="Background" Value="{DynamicResource PmDropzoneBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmDropzoneBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>

        <Style Selector="Border.pm-dropzone.drag-over">
            <Setter Property="Background" Value="{DynamicResource PmDropzoneDragBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmDropzoneDragBorderBrush}"/>
        </Style>

        <Style Selector="Border.pm-stat">
            <Setter Property="Background" Value="{DynamicResource PmStatBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmStatBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="MinWidth" Value="0"/>
        </Style>

        <Style Selector="ProgressBar">
            <Setter Property="Height" Value="6"/>
        </Style>
    </Application.Styles>
</Application>
