<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PotatoMaker.GUI.ViewModels"
             xmlns:views="using:PotatoMaker.GUI.Views"
             x:Class="PotatoMaker.GUI.App"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <DataTemplate DataType="vm:EncodeWorkspaceViewModel">
            <views:MainWorkspaceView/>
        </DataTemplate>
        <DataTemplate DataType="vm:FileInputViewModel">
            <views:FileInputView/>
        </DataTemplate>
        <DataTemplate DataType="vm:VideoSummaryViewModel">
            <views:VideoSummaryView/>
        </DataTemplate>
        <DataTemplate DataType="vm:OutputSettingsViewModel">
            <views:OutputSettingsView/>
        </DataTemplate>
        <DataTemplate DataType="vm:ConversionLogViewModel">
            <views:ConversionLogView/>
        </DataTemplate>
        <DataTemplate DataType="vm:SettingsViewModel">
            <views:SettingsView/>
        </DataTemplate>
        <DataTemplate DataType="vm:HelpViewModel">
            <views:HelpView/>
        </DataTemplate>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="PmWindowBackground">#FFF2F4F8</SolidColorBrush>
                    <SolidColorBrush x:Key="PmCardBackground">#FFFFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="PmCardBorderBrush">#FFD7DCE5</SolidColorBrush>
                    <LinearGradientBrush x:Key="PmHeroBackground" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFEAF1FA" Offset="0"/>
                        <GradientStop Color="#FFDEE8F5" Offset="1"/>
                    </LinearGradientBrush>
                    <SolidColorBrush x:Key="PmHeroBorderBrush">#FFC8D7EA</SolidColorBrush>
                    <SolidColorBrush x:Key="PmHeadingForeground">#FF151D2B</SolidColorBrush>
                    <SolidColorBrush x:Key="PmSectionTitleForeground">#FF223045</SolidColorBrush>
                    <SolidColorBrush x:Key="PmMutedForeground">#FF5A667B</SolidColorBrush>
                    <SolidColorBrush x:Key="PmNavSurfaceBackground">#FFF8FAFD</SolidColorBrush>
                    <SolidColorBrush x:Key="PmNavSurfaceBorderBrush">#FFD8E0EA</SolidColorBrush>
                    <SolidColorBrush x:Key="PmNavItemBackground">#00000000</SolidColorBrush>
                    <SolidColorBrush x:Key="PmNavItemPointerOver">#FFEAF1FA</SolidColorBrush>
                    <SolidColorBrush x:Key="PmNavItemSelectedBackground">#FFDDE9F9</SolidColorBrush>
                    <SolidColorBrush x:Key="PmNavItemSelectedBorderBrush">#FFB9CDE8</SolidColorBrush>
                    <SolidColorBrush x:Key="PmNavItemForeground">#FF223045</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPageBannerBackground">#FFF5F8FC</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPageBannerBorderBrush">#FFD5DFEC</SolidColorBrush>
                    <SolidColorBrush x:Key="PmHelpBadgeBackground">#FFE1EAF7</SolidColorBrush>
                    <SolidColorBrush x:Key="PmHelpBadgeBorderBrush">#FFC3D2E5</SolidColorBrush>
                    <SolidColorBrush x:Key="PmUpdateDotBackground">#FF1E8E3E</SolidColorBrush>
                    <SolidColorBrush x:Key="PmUpdatePanelBackground">#FFFFF2DE</SolidColorBrush>
                    <SolidColorBrush x:Key="PmUpdatePanelBorderBrush">#FFE8C98B</SolidColorBrush>

                    <SolidColorBrush x:Key="PmPrimaryBackground">#FF176FE5</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPrimaryPointerOver">#FF267BEF</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPrimaryPressed">#FF0E5EC8</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPrimaryBorder">#FF3A86EA</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPrimaryDisabledBackground">#FFE4E8EF</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPrimaryDisabledBorder">#FFD3D9E4</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPrimaryDisabledForeground">#FF7A8699</SolidColorBrush>
                    <SolidColorBrush x:Key="PmTrimStartBackground">#FF2FA36B</SolidColorBrush>
                    <SolidColorBrush x:Key="PmTrimRangeBackground">#FF9DDFB8</SolidColorBrush>
                    <SolidColorBrush x:Key="PmCancelBackground">#FFD24B4B</SolidColorBrush>
                    <SolidColorBrush x:Key="PmCancelPointerOver">#FFDF5B5B</SolidColorBrush>
                    <SolidColorBrush x:Key="PmCancelPressed">#FFB63F3F</SolidColorBrush>
                    <SolidColorBrush x:Key="PmCancelBorder">#FFCC6A6A</SolidColorBrush>

                    <SolidColorBrush x:Key="PmDropzoneBackground">#FFF6F9FD</SolidColorBrush>
                    <SolidColorBrush x:Key="PmDropzoneBorderBrush">#FFB4C3D8</SolidColorBrush>
                    <SolidColorBrush x:Key="PmDropzoneDragBackground">#FFE9F1FB</SolidColorBrush>
                    <SolidColorBrush x:Key="PmDropzoneDragBorderBrush">#FF4E7EB8</SolidColorBrush>

                    <SolidColorBrush x:Key="PmStatBackground">#FFF6F8FB</SolidColorBrush>
                    <SolidColorBrush x:Key="PmStatBorderBrush">#FFD6DEE9</SolidColorBrush>
                    <SolidColorBrush x:Key="PmInsetBackground">#FFF4F7FB</SolidColorBrush>
                    <SolidColorBrush x:Key="PmInsetBorderBrush">#FFD6DEE8</SolidColorBrush>
                    <SolidColorBrush x:Key="PmStatusIdleForeground">#FF334257</SolidColorBrush>
                    <SolidColorBrush x:Key="PmStatusAnalysingForeground">#FF245B9A</SolidColorBrush>
                    <SolidColorBrush x:Key="PmStatusEncodingForeground">#FF1E6A45</SolidColorBrush>
                    <SolidColorBrush x:Key="PmStatusCancelledForeground">#FF8C5B15</SolidColorBrush>
                    <SolidColorBrush x:Key="PmStatusErrorForeground">#FFA83A3A</SolidColorBrush>
                    <SolidColorBrush x:Key="PmStatusDoneForeground">#FF1E6A45</SolidColorBrush>
                    <SolidColorBrush x:Key="PmVideoSurfaceBackground">#FF0B0E14</SolidColorBrush>
                    <SolidColorBrush x:Key="PmVideoSurfaceBorderBrush">#FF2B3340</SolidColorBrush>
                    <SolidColorBrush x:Key="PmVideoEmptyBackground">#FFE8EEF6</SolidColorBrush>
                    <SolidColorBrush x:Key="PmErrorForeground">#FFBC3030</SolidColorBrush>
                </ResourceDictionary>

                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="PmWindowBackground">#FF0E1116</SolidColorBrush>
                    <SolidColorBrush x:Key="PmCardBackground">#FF1A202A</SolidColorBrush>
                    <SolidColorBrush x:Key="PmCardBorderBrush">#FF2A3342</SolidColorBrush>
                    <LinearGradientBrush x:Key="PmHeroBackground" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF243448" Offset="0"/>
                        <GradientStop Color="#FF161E29" Offset="1"/>
                    </LinearGradientBrush>
                    <SolidColorBrush x:Key="PmHeroBorderBrush">#FF3A4D67</SolidColorBrush>
                    <SolidColorBrush x:Key="PmHeadingForeground">#FFF2F7FF</SolidColorBrush>
                    <SolidColorBrush x:Key="PmSectionTitleForeground">#FFE7EDF7</SolidColorBrush>
                    <SolidColorBrush x:Key="PmMutedForeground">#FFD3DCEC</SolidColorBrush>
                    <SolidColorBrush x:Key="PmNavSurfaceBackground">#FF151B25</SolidColorBrush>
                    <SolidColorBrush x:Key="PmNavSurfaceBorderBrush">#FF273243</SolidColorBrush>
                    <SolidColorBrush x:Key="PmNavItemBackground">#00000000</SolidColorBrush>
                    <SolidColorBrush x:Key="PmNavItemPointerOver">#FF1F2937</SolidColorBrush>
                    <SolidColorBrush x:Key="PmNavItemSelectedBackground">#FF243448</SolidColorBrush>
                    <SolidColorBrush x:Key="PmNavItemSelectedBorderBrush">#FF3B516D</SolidColorBrush>
                    <SolidColorBrush x:Key="PmNavItemForeground">#FFE7EDF7</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPageBannerBackground">#FF141B24</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPageBannerBorderBrush">#FF2A3547</SolidColorBrush>
                    <SolidColorBrush x:Key="PmHelpBadgeBackground">#FF233246</SolidColorBrush>
                    <SolidColorBrush x:Key="PmHelpBadgeBorderBrush">#FF3A4F68</SolidColorBrush>
                    <SolidColorBrush x:Key="PmUpdateDotBackground">#FF5FC779</SolidColorBrush>
                    <SolidColorBrush x:Key="PmUpdatePanelBackground">#FF2C2416</SolidColorBrush>
                    <SolidColorBrush x:Key="PmUpdatePanelBorderBrush">#FF6C5531</SolidColorBrush>

                    <SolidColorBrush x:Key="PmPrimaryBackground">#FF3A7AFE</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPrimaryPointerOver">#FF4A86FF</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPrimaryPressed">#FF2A68E8</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPrimaryBorder">#FF5A91FF</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPrimaryDisabledBackground">#FF2A3342</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPrimaryDisabledBorder">#FF2A3342</SolidColorBrush>
                    <SolidColorBrush x:Key="PmPrimaryDisabledForeground">#FF98A6BB</SolidColorBrush>
                    <SolidColorBrush x:Key="PmTrimStartBackground">#FF41B87E</SolidColorBrush>
                    <SolidColorBrush x:Key="PmTrimRangeBackground">#FF5A9C74</SolidColorBrush>
                    <SolidColorBrush x:Key="PmCancelBackground">#FFC65252</SolidColorBrush>
                    <SolidColorBrush x:Key="PmCancelPointerOver">#FFD26262</SolidColorBrush>
                    <SolidColorBrush x:Key="PmCancelPressed">#FFAA4747</SolidColorBrush>
                    <SolidColorBrush x:Key="PmCancelBorder">#FFD07878</SolidColorBrush>

                    <SolidColorBrush x:Key="PmDropzoneBackground">#FF151B25</SolidColorBrush>
                    <SolidColorBrush x:Key="PmDropzoneBorderBrush">#FF41506A</SolidColorBrush>
                    <SolidColorBrush x:Key="PmDropzoneDragBackground">#FF1E2A3A</SolidColorBrush>
                    <SolidColorBrush x:Key="PmDropzoneDragBorderBrush">#FF5F95FF</SolidColorBrush>

                    <SolidColorBrush x:Key="PmStatBackground">#FF121821</SolidColorBrush>
                    <SolidColorBrush x:Key="PmStatBorderBrush">#FF273143</SolidColorBrush>
                    <SolidColorBrush x:Key="PmInsetBackground">#FF0F141C</SolidColorBrush>
                    <SolidColorBrush x:Key="PmInsetBorderBrush">#FF273143</SolidColorBrush>
                    <SolidColorBrush x:Key="PmStatusIdleForeground">#FFD6DFED</SolidColorBrush>
                    <SolidColorBrush x:Key="PmStatusAnalysingForeground">#FF9BC4FF</SolidColorBrush>
                    <SolidColorBrush x:Key="PmStatusEncodingForeground">#FF98E0B7</SolidColorBrush>
                    <SolidColorBrush x:Key="PmStatusCancelledForeground">#FFF0C27C</SolidColorBrush>
                    <SolidColorBrush x:Key="PmStatusErrorForeground">#FFFFA5A5</SolidColorBrush>
                    <SolidColorBrush x:Key="PmStatusDoneForeground">#FF9BE1B8</SolidColorBrush>
                    <SolidColorBrush x:Key="PmVideoSurfaceBackground">#FF05070B</SolidColorBrush>
                    <SolidColorBrush x:Key="PmVideoSurfaceBorderBrush">#FF2A3342</SolidColorBrush>
                    <SolidColorBrush x:Key="PmVideoEmptyBackground">#FF0B1017</SolidColorBrush>
                    <SolidColorBrush x:Key="PmErrorForeground">#FFFF8E8E</SolidColorBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <Style Selector="Window">
            <Setter Property="Background" Value="{DynamicResource PmWindowBackground}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style Selector="Border.pm-card">
            <Setter Property="Background" Value="{DynamicResource PmCardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmCardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>

        <Style Selector="Border.pm-hero">
            <Setter Property="Background" Value="{DynamicResource PmHeroBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmHeroBorderBrush}"/>
        </Style>

        <Style Selector="Border.pm-nav-surface">
            <Setter Property="Background" Value="{DynamicResource PmNavSurfaceBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmNavSurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>

        <Style Selector="Border.pm-inset">
            <Setter Property="Background" Value="{DynamicResource PmInsetBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmInsetBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style Selector="Border.pm-video-surface">
            <Setter Property="Background" Value="{DynamicResource PmVideoSurfaceBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmVideoSurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>

        <Style Selector="TextBlock.pm-heading">
            <Setter Property="FontFamily" Value="Bahnschrift,Segoe UI Semibold"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="{DynamicResource PmHeadingForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-section-title">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource PmSectionTitleForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-page-title">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="{DynamicResource PmHeadingForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-nav-brand">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource PmMutedForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-nav-icon">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons,Segoe MDL2 Assets"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource PmMutedForeground}"/>
        </Style>

        <Style Selector="Border.pm-sidebar-version">
            <Setter Property="Background" Value="{DynamicResource PmHelpBadgeBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmHelpBadgeBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style Selector="TextBlock.pm-sidebar-version-text">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PmNavItemForeground}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style Selector="TextBlock.pm-settings-label">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PmSectionTitleForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-muted">
            <Setter Property="Opacity" Value="0.82"/>
            <Setter Property="Foreground" Value="{DynamicResource PmMutedForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-caption">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Opacity" Value="0.82"/>
            <Setter Property="Foreground" Value="{DynamicResource PmMutedForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-status-accent">
            <Setter Property="Foreground" Value="{DynamicResource PmStatusIdleForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-status-accent.pm-status-analysing">
            <Setter Property="Foreground" Value="{DynamicResource PmStatusAnalysingForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-status-accent.pm-status-encoding">
            <Setter Property="Foreground" Value="{DynamicResource PmStatusEncodingForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-status-accent.pm-status-cancelled">
            <Setter Property="Foreground" Value="{DynamicResource PmStatusCancelledForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-status-accent.pm-status-error">
            <Setter Property="Foreground" Value="{DynamicResource PmStatusErrorForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-status-accent.pm-status-done">
            <Setter Property="Foreground" Value="{DynamicResource PmStatusDoneForeground}"/>
        </Style>

        <Style Selector="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="30"/>
        </Style>

        <Style Selector="Button.pm-nav-button">
            <Setter Property="Background" Value="{DynamicResource PmNavItemBackground}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource PmNavItemForeground}"/>
            <Setter Property="MinHeight" Value="46"/>
            <Setter Property="MinWidth" Value="46"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style Selector="Button.pm-nav-button:pointerover">
            <Setter Property="Background" Value="{DynamicResource PmNavItemPointerOver}"/>
        </Style>

        <Style Selector="Button.pm-nav-button.pm-nav-active">
            <Setter Property="Background" Value="{DynamicResource PmNavItemSelectedBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmNavItemSelectedBorderBrush}"/>
        </Style>

        <Style Selector="Button.pm-nav-button.pm-nav-active TextBlock.pm-nav-icon">
            <Setter Property="Foreground" Value="{DynamicResource PmSectionTitleForeground}"/>
        </Style>

        <Style Selector="Border.pm-update-dot">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Background" Value="{DynamicResource PmUpdateDotBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmCardBackground}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>

        <Style Selector="Border.pm-update-panel">
            <Setter Property="Background" Value="{DynamicResource PmUpdatePanelBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmUpdatePanelBorderBrush}"/>
        </Style>

        <Style Selector="Button.pm-primary">
            <Setter Property="Background" Value="{DynamicResource PmPrimaryBackground}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmPrimaryBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style Selector="Button.pm-primary:pointerover">
            <Setter Property="Background" Value="{DynamicResource PmPrimaryPointerOver}"/>
        </Style>

        <Style Selector="Button.pm-primary:pressed">
            <Setter Property="Background" Value="{DynamicResource PmPrimaryPressed}"/>
        </Style>

        <Style Selector="Button.pm-primary:disabled">
            <Setter Property="Background" Value="{DynamicResource PmPrimaryDisabledBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmPrimaryDisabledBorder}"/>
            <Setter Property="Foreground" Value="{DynamicResource PmPrimaryDisabledForeground}"/>
        </Style>

        <Style Selector="Button.pm-cancel">
            <Setter Property="Background" Value="{DynamicResource PmCancelBackground}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmCancelBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style Selector="Button.pm-cancel:pointerover">
            <Setter Property="Background" Value="{DynamicResource PmCancelPointerOver}"/>
        </Style>

        <Style Selector="Button.pm-cancel:pressed">
            <Setter Property="Background" Value="{DynamicResource PmCancelPressed}"/>
        </Style>

        <Style Selector="Button.pm-cancel:disabled">
            <Setter Property="Background" Value="{DynamicResource PmPrimaryDisabledBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmPrimaryDisabledBorder}"/>
            <Setter Property="Foreground" Value="{DynamicResource PmPrimaryDisabledForeground}"/>
        </Style>

        <Style Selector="Border.pm-dropzone">
            <Setter Property="Background" Value="{DynamicResource PmDropzoneBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmDropzoneBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>

        <Style Selector="Border.pm-dropzone.drag-over">
            <Setter Property="Background" Value="{DynamicResource PmDropzoneDragBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmDropzoneDragBorderBrush}"/>
        </Style>

        <Style Selector="Border.pm-stat">
            <Setter Property="Background" Value="{DynamicResource PmStatBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmStatBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="MinWidth" Value="0"/>
        </Style>

        <Style Selector="Border.pm-page-banner">
            <Setter Property="Background" Value="{DynamicResource PmPageBannerBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmPageBannerBorderBrush}"/>
        </Style>

        <Style Selector="Border.pm-help-badge">
            <Setter Property="Background" Value="{DynamicResource PmHelpBadgeBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmHelpBadgeBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>

        <Style Selector="ProgressBar">
            <Setter Property="Height" Value="6"/>
        </Style>
    </Application.Styles>
</Application>
