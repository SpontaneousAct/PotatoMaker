        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <Style Selector="Window">
            <Setter Property="Background" Value="{DynamicResource PmWindowBackground}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style Selector="Border.pm-card">
            <Setter Property="Background" Value="{DynamicResource PmCardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmCardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>

        <Style Selector="Border.pm-hero">
            <Setter Property="Background" Value="{DynamicResource PmHeroBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmHeroBorderBrush}"/>
        </Style>

        <Style Selector="Border.pm-nav-surface">
            <Setter Property="Background" Value="{DynamicResource PmNavSurfaceBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmNavSurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>

        <Style Selector="Border.pm-inset">
            <Setter Property="Background" Value="{DynamicResource PmInsetBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmInsetBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style Selector="Border.pm-video-surface">
            <Setter Property="Background" Value="{DynamicResource PmVideoSurfaceBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmVideoSurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>

        <Style Selector="TextBlock.pm-heading">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="{DynamicResource PmHeadingForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-section-title">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource PmSectionTitleForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-page-title">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="{DynamicResource PmHeadingForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-nav-brand">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource PmMutedForeground}"/>
        </Style>

        <Style Selector="Grid.pm-nav-icon">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="Path.pm-nav-icon-path">
            <Setter Property="Stroke" Value="{DynamicResource PmMutedForeground}"/>
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="Path.pm-nav-icon-fill">
            <Setter Property="Fill" Value="{DynamicResource PmMutedForeground}"/>
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="Border.pm-sidebar-version">
            <Setter Property="Background" Value="{DynamicResource PmHelpBadgeBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmHelpBadgeBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style Selector="TextBlock.pm-sidebar-version-text">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PmNavItemForeground}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style Selector="TextBlock.pm-settings-label">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PmSectionTitleForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-muted">
            <Setter Property="Opacity" Value="0.82"/>
            <Setter Property="Foreground" Value="{DynamicResource PmMutedForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-caption">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Opacity" Value="0.82"/>
            <Setter Property="Foreground" Value="{DynamicResource PmMutedForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-status-accent">
            <Setter Property="Foreground" Value="{DynamicResource PmStatusIdleForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-status-accent.pm-status-analysing">
            <Setter Property="Foreground" Value="{DynamicResource PmStatusAnalysingForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-status-accent.pm-status-encoding">
            <Setter Property="Foreground" Value="{DynamicResource PmStatusEncodingForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-status-accent.pm-status-cancelled">
            <Setter Property="Foreground" Value="{DynamicResource PmStatusCancelledForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-status-accent.pm-status-error">
            <Setter Property="Foreground" Value="{DynamicResource PmStatusErrorForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-status-accent.pm-status-done">
            <Setter Property="Foreground" Value="{DynamicResource PmStatusDoneForeground}"/>
        </Style>

        <Style Selector="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="30"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Background" Value="{DynamicResource PmFieldBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PmFieldBorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PmSectionTitleForeground}"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>

