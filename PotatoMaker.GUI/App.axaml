<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PotatoMaker.GUI.ViewModels"
             xmlns:views="using:PotatoMaker.GUI.Views"
             x:Class="PotatoMaker.GUI.App"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <DataTemplate DataType="vm:EncodeWorkspaceViewModel">
            <views:MainWorkspaceView/>
        </DataTemplate>
        <DataTemplate DataType="vm:CompressionQueueViewModel">
            <views:CompressionQueueView/>
        </DataTemplate>
        <DataTemplate DataType="vm:FileInputViewModel">
            <views:FileInputView/>
        </DataTemplate>
        <DataTemplate DataType="vm:VideoSummaryViewModel">
            <views:VideoSummaryView/>
        </DataTemplate>
        <DataTemplate DataType="vm:OutputSettingsViewModel">
            <views:OutputSettingsView/>
        </DataTemplate>
        <DataTemplate DataType="vm:ConversionLogViewModel">
            <views:ConversionLogView/>
        </DataTemplate>
        <DataTemplate DataType="vm:SettingsViewModel">
            <views:SettingsView/>
        </DataTemplate>
        <DataTemplate DataType="vm:HelpViewModel">
            <views:HelpView/>
        </DataTemplate>
    </Application.DataTemplates>

