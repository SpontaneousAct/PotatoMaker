<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PotatoMaker.GUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="320" d:DesignHeight="220"
             x:Class="PotatoMaker.GUI.Views.OutputSettingsView"
             x:DataType="vm:OutputSettingsViewModel">

    <Design.DataContext>
        <vm:OutputSettingsViewModel/>
    </Design.DataContext>

    <Border Classes="pm-card"
            Padding="12">
        <StackPanel Spacing="8">
            <StackPanel Spacing="2">
                <TextBlock Text="Save Output"
                           Classes="pm-section-title"/>
                <TextBlock Text="Choose where the encoded file should be written."
                           Classes="pm-caption"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <Border x:Name="OutputFolderHost"
                    Classes="pm-inset"
                    MinHeight="56"
                    Cursor="Hand"
                    PointerReleased="OnOutputFolderHostPointerReleased">
                <StackPanel Spacing="2"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Stretch">
                    <ToolTip.Tip>
                        <StackPanel Spacing="4"
                                    MaxWidth="640">
                            <TextBlock Text="{Binding OutputFolderDisplayWrapped}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="Click to open this folder in Explorer."
                                       Classes="pm-caption"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </ToolTip.Tip>
                    <TextBlock Text="{Binding OutputFolderDisplayWrapped}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="2"/>
                </StackPanel>
            </Border>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="8">
                <Button Grid.Column="0"
                        Content="Choose"
                        Command="{Binding SelectOutputFolderCommand}"
                        HorizontalAlignment="Stretch"/>
                <Button Grid.Column="1"
                        Content="Reset"
                        Command="{Binding ResetOutputFolderCommand}"
                        IsEnabled="{Binding CanResetOutputFolder}"
                        ToolTip.Tip="Defaults to source file folder"
                        HorizontalAlignment="Stretch"/>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
