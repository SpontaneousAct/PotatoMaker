<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PotatoMaker.GUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="320" d:DesignHeight="288"
             x:Class="PotatoMaker.GUI.Views.OutputSettingsView"
             x:DataType="vm:OutputSettingsViewModel">

    <Design.DataContext>
        <vm:OutputSettingsViewModel/>
    </Design.DataContext>

    <Border Classes="pm-card"
            Padding="8"
            MinHeight="288">
        <StackPanel Spacing="6">
            <TextBlock Text="Output"
                       Classes="pm-section-title"/>

            <CheckBox Content="Use NVENC AV1 (GPU)"
                      IsChecked="{Binding UseNvencEncoder}"
                      IsEnabled="{Binding CanUseNvenc}"/>

            <TextBlock Text="{Binding NvencSupportSummary}"
                       Classes="pm-caption"
                       TextWrapping="Wrap"/>

            <TextBlock Text="CPU preset"
                       Classes="pm-caption"/>

            <ComboBox ItemsSource="{Binding CpuEncodePresetOptions}"
                      SelectedItem="{Binding SelectedCpuEncodePreset}"
                      HorizontalAlignment="Stretch"/>

            <TextBlock Text="Folder"
                       Classes="pm-caption"/>

            <Border x:Name="OutputFolderHost"
                    Classes="pm-inset"
                    MinHeight="56">
                <StackPanel Spacing="2"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Stretch">
                    <ToolTip.Tip>
                        <TextBlock Text="{Binding OutputFolderDisplayWrapped}"
                                   TextWrapping="Wrap"
                                   MaxWidth="640"/>
                    </ToolTip.Tip>
                    <TextBlock Text="{Binding OutputFolderDisplayWrapped}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="2"/>
                </StackPanel>
            </Border>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="6">
                <Button Grid.Column="0"
                        Content="Choose"
                        Command="{Binding SelectOutputFolderCommand}"
                        HorizontalAlignment="Stretch"/>
                <Button Grid.Column="1"
                        Content="Reset"
                        Command="{Binding ResetOutputFolderCommand}"
                        IsEnabled="{Binding CanResetOutputFolder}"
                        ToolTip.Tip="Defaults to source file folder"
                        HorizontalAlignment="Stretch"/>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
