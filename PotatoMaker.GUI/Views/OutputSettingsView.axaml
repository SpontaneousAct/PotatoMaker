<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PotatoMaker.GUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="560" d:DesignHeight="80"
             x:Class="PotatoMaker.GUI.Views.OutputSettingsView"
             x:DataType="vm:OutputSettingsViewModel">

    <Design.DataContext>
        <vm:OutputSettingsViewModel/>
    </Design.DataContext>

    <Border Padding="16"
            CornerRadius="8"
            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
        <StackPanel Spacing="6">
            <TextBlock Text="Output Settings" FontWeight="SemiBold" FontSize="14"/>
            <Separator/>
            <CheckBox Content="Use CPU encoder (libsvtav1 — slower, no GPU needed)"
                      IsChecked="{Binding UseCpuEncoder}"
                      Margin="0,4,0,0"/>
        </StackPanel>
    </Border>
</UserControl>
