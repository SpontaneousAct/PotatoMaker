<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PotatoMaker.GUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="280" d:DesignHeight="160"
             x:Class="PotatoMaker.GUI.Views.OutputSettingsView"
             x:DataType="vm:OutputSettingsViewModel">

    <Design.DataContext>
        <vm:OutputSettingsViewModel/>
    </Design.DataContext>

    <Border Classes="pm-card"
            Padding="10">
        <StackPanel Spacing="8">
            <TextBlock Text="Output"
                       Classes="pm-section-title"/>

            <CheckBox Content="Use CPU encoder"
                      IsChecked="{Binding UseCpuEncoder}"/>

            <TextBlock Text="Folder"
                       Classes="pm-muted"/>

            <Border Background="{DynamicResource PmInsetBackground}"
                    x:Name="OutputFolderHost"
                    BorderBrush="{DynamicResource PmInsetBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10,8"
                    MinHeight="52">
                <StackPanel Spacing="0"
                            VerticalAlignment="Center">
                    <ToolTip.Tip>
                        <TextBlock Text="{Binding OutputFolderPath, TargetNullValue=Source file folder}"
                                   TextWrapping="Wrap"
                                   MaxWidth="640"/>
                    </ToolTip.Tip>
                    <TextBlock x:Name="OutputFolderLine1"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="OutputFolderLine2"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"
                               IsVisible="False"/>
                </StackPanel>
            </Border>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="8">
                <Button Grid.Column="0"
                        Content="Choose"
                        Command="{Binding SelectOutputFolderCommand}"
                        HorizontalAlignment="Stretch"/>
                <Button Grid.Column="1"
                        Content="Reset"
                        Command="{Binding ResetOutputFolderCommand}"
                        IsEnabled="{Binding CanResetOutputFolder}"
                        ToolTip.Tip="Defaults to source file folder"
                        HorizontalAlignment="Stretch"/>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
