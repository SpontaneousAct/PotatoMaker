<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PotatoMaker.GUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="240" d:DesignHeight="120"
             x:Class="PotatoMaker.GUI.Views.OutputSettingsView"
             x:DataType="vm:OutputSettingsViewModel">

    <Design.DataContext>
        <vm:OutputSettingsViewModel/>
    </Design.DataContext>

    <Border Classes="pm-card"
            Padding="12">
        <StackPanel Spacing="8">
            <TextBlock Text="Settings"
                       Classes="pm-section-title"/>
            <CheckBox Content="CPU encoder (slower)"
                      IsChecked="{Binding UseCpuEncoder}"/>
            <TextBlock Text="Unchecked = NVENC with CPU fallback"
                       Classes="pm-muted"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </Border>
</UserControl>
