<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PotatoMaker.GUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="320" d:DesignHeight="260"
             x:Class="PotatoMaker.GUI.Views.VideoSummaryView"
             x:DataType="vm:VideoSummaryViewModel">

    <Design.DataContext>
        <vm:VideoSummaryViewModel/>
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="TextBlock.pm-summary-title">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource PmSectionTitleForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-summary-caption">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Opacity" Value="0.82"/>
            <Setter Property="Foreground" Value="{DynamicResource PmMutedForeground}"/>
        </Style>

        <Style Selector="TextBlock.pm-summary-value">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="LineHeight" Value="16"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="TextTrimming" Value="WordEllipsis"/>
            <Setter Property="MaxLines" Value="2"/>
        </Style>

        <Style Selector="TextBlock.pm-summary-value.pm-summary-value-compact">
            <Setter Property="MinHeight" Value="20"/>
            <Setter Property="MaxLines" Value="1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <Border Classes="pm-card"
            Padding="10">
        <Grid RowDefinitions="Auto,Auto,Auto,*"
              RowSpacing="6">
            <TextBlock Grid.Row="0"
                       Text="Selected Clip"
                       Classes="pm-summary-title"/>

            <Border Grid.Row="1"
                    Classes="pm-inset"
                    Padding="8,4">
                <Grid ColumnDefinitions="*,*,*"
                      ColumnSpacing="8">
                    <StackPanel Grid.Column="0"
                                Spacing="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="Start" Classes="pm-summary-caption"/>
                        <TextBlock Text="{Binding SelectedStart, TargetNullValue=--}"
                                   Classes="pm-summary-value pm-summary-value-compact"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Spacing="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="End" Classes="pm-summary-caption"/>
                        <TextBlock Text="{Binding SelectedEnd, TargetNullValue=--}"
                                   Classes="pm-summary-value pm-summary-value-compact"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Spacing="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="Length" Classes="pm-summary-caption"/>
                        <TextBlock Text="{Binding SelectedDuration, TargetNullValue=--}"
                                   Classes="pm-summary-value pm-summary-value-compact"/>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2"
                        Spacing="2">
                <TextBlock Text="Strategy Preview"
                           Classes="pm-summary-title"/>
            </StackPanel>

            <Grid Grid.Row="3"
                  ColumnDefinitions="*,*"
                  RowDefinitions="Auto,Auto,Auto"
                  RowSpacing="6"
                  ColumnSpacing="6">
                <StackPanel Grid.Row="0"
                            Grid.Column="0"
                            Spacing="1">
                    <TextBlock Text="Resolution" Classes="pm-summary-caption"/>
                    <TextBlock Text="{Binding StrategyResolution, TargetNullValue=--}"
                               Classes="pm-summary-value"/>
                </StackPanel>

                <StackPanel Grid.Row="0"
                            Grid.Column="1"
                            Spacing="1">
                    <TextBlock Text="Bitrate" Classes="pm-summary-caption"/>
                    <TextBlock Text="{Binding StrategyBitrate, TargetNullValue=--}"
                               Classes="pm-summary-value"/>
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Grid.ColumnSpan="2"
                            Spacing="1">
                    <TextBlock Text="Parts" Classes="pm-summary-caption"/>
                    <TextBlock Text="{Binding StrategyParts, TargetNullValue=--}"
                               Classes="pm-summary-value"/>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Grid.Column="0"
                            Spacing="4">
                    <TextBlock Text="Crop mode" Classes="pm-summary-caption"/>
                    <StackPanel Spacing="2">
                        <ComboBox ItemsSource="{Binding CropOptions}"
                                  SelectedItem="{Binding SelectedCropOption}"
                                  IsEnabled="{Binding CanSelectCropMode}"
                                  HorizontalAlignment="Stretch"/>
                        <TextBlock Text="{Binding CropModeHelperText}"
                                   IsVisible="{Binding IsCropModeHelperVisible}"
                                   Classes="pm-summary-caption"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Grid.Column="1"
                            Spacing="4">
                    <TextBlock Text="Frame rate" Classes="pm-summary-caption"/>
                    <ComboBox ItemsSource="{Binding FrameRateOptions}"
                              SelectedItem="{Binding SelectedFrameRateOption}"
                              IsEnabled="{Binding CanSelectFrameRate}"
                              HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
