<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PotatoMaker.GUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="320" d:DesignHeight="360"
             x:Class="PotatoMaker.GUI.Views.VideoSummaryView"
             x:DataType="vm:VideoSummaryViewModel">

    <Design.DataContext>
        <vm:VideoSummaryViewModel/>
    </Design.DataContext>

    <Border Classes="pm-card"
            Padding="8"
            MinHeight="0"
            ClipToBounds="True">
        <Grid RowDefinitions="Auto,Auto,*"
              RowSpacing="6"
              MinHeight="0">
            <TextBlock Text="Video"
                       Classes="pm-section-title"
                       Grid.Row="0"/>

            <Grid ColumnDefinitions="*,*"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="5"
                  ColumnSpacing="5"
                  Grid.Row="1">
                <Border Grid.Row="0"
                        Grid.Column="0"
                        Classes="pm-stat">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Size" Classes="pm-caption"/>
                        <TextBlock Text="{Binding FileSize, TargetNullValue=--}"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="0"
                        Grid.Column="1"
                        Classes="pm-stat">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Duration" Classes="pm-caption"/>
                        <TextBlock Text="{Binding Duration, TargetNullValue=--}"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Grid.Column="0"
                        Classes="pm-stat">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Resolution" Classes="pm-caption"/>
                        <TextBlock Text="{Binding Resolution, TargetNullValue=--}"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Grid.Column="1"
                        Classes="pm-stat">
                    <StackPanel Spacing="2">
                        <TextBlock Text="FPS" Classes="pm-caption"/>
                        <TextBlock Text="{Binding FrameRate, TargetNullValue=--}"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Classes="pm-stat"
                    Grid.Row="2"
                    MinHeight="0"
                    ClipToBounds="True">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="5"
                      MinHeight="0">
                    <TextBlock Grid.Row="0"
                               Text="Strategy Preview"
                               Classes="pm-section-title"/>

                    <ScrollViewer Grid.Row="1"
                                  MinHeight="0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid ColumnDefinitions="*,*"
                              RowDefinitions="Auto,Auto,Auto"
                              RowSpacing="5"
                              ColumnSpacing="5">
                            <StackPanel Grid.Row="0"
                                        Grid.Column="0"
                                        Spacing="1">
                                <TextBlock Text="Resolution" Classes="pm-caption"/>
                                <TextBlock Text="{Binding StrategyResolution, TargetNullValue=--}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0"
                                        Grid.Column="1"
                                        Spacing="1">
                                <TextBlock Text="Bitrate" Classes="pm-caption"/>
                                <TextBlock Text="{Binding StrategyBitrate, TargetNullValue=--}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                        Grid.Column="0"
                                        Spacing="1">
                                <TextBlock Text="Parts" Classes="pm-caption"/>
                                <TextBlock Text="{Binding StrategyParts, TargetNullValue=--}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                        Grid.Column="1"
                                        Spacing="1">
                                <TextBlock Text="Crop" Classes="pm-caption"/>
                                <TextBlock Text="{Binding StrategyCrop, TargetNullValue=--}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2"
                                        Grid.ColumnSpan="2"
                                        Spacing="1">
                                <TextBlock Text="FFmpeg filter" Classes="pm-caption"/>
                                <TextBlock Text="{Binding StrategyFilter, TargetNullValue=--}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
