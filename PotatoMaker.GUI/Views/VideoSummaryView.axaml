<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PotatoMaker.GUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="320" d:DesignHeight="230"
             x:Class="PotatoMaker.GUI.Views.VideoSummaryView"
             x:DataType="vm:VideoSummaryViewModel">

    <Design.DataContext>
        <vm:VideoSummaryViewModel/>
    </Design.DataContext>

    <Border Classes="pm-card"
            Padding="8">
        <Grid RowDefinitions="Auto,Auto,*"
              RowSpacing="5">
            <TextBlock Grid.Row="0"
                       Text="Strategy Preview"
                       Classes="pm-section-title"/>

            <Grid Grid.Row="2"
                  ColumnDefinitions="*,*"
                  RowDefinitions="Auto,Auto,Auto"
                  RowSpacing="5"
                  ColumnSpacing="5">
                <StackPanel Grid.Row="0"
                            Grid.Column="0"
                            Spacing="1">
                    <TextBlock Text="Resolution" Classes="pm-caption"/>
                    <TextBlock Text="{Binding StrategyResolution, TargetNullValue=--}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <StackPanel Grid.Row="0"
                            Grid.Column="1"
                            Spacing="1">
                    <TextBlock Text="Bitrate" Classes="pm-caption"/>
                    <TextBlock Text="{Binding StrategyBitrate, TargetNullValue=--}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Grid.Column="0"
                            Spacing="1">
                    <TextBlock Text="Parts" Classes="pm-caption"/>
                    <TextBlock Text="{Binding StrategyParts, TargetNullValue=--}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Grid.Column="1"
                            Spacing="1">
                    <TextBlock Text="Crop" Classes="pm-caption"/>
                    <TextBlock Text="{Binding StrategyCrop, TargetNullValue=--}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Spacing="1">
                    <TextBlock Text="FFmpeg filter" Classes="pm-caption"/>
                    <TextBlock Text="{Binding StrategyFilter, TargetNullValue=--}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
