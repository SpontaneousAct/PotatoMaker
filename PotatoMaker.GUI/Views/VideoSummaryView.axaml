<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PotatoMaker.GUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="560" d:DesignHeight="100"
             x:Class="PotatoMaker.GUI.Views.VideoSummaryView"
             x:DataType="vm:VideoSummaryViewModel">

    <Design.DataContext>
        <vm:VideoSummaryViewModel/>
    </Design.DataContext>

    <Border Classes="card"
            Padding="16"
            CornerRadius="8"
            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
        <StackPanel Spacing="6">
            <TextBlock Text="Video Info" FontWeight="SemiBold" FontSize="14"/>
            <Separator/>
            <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto" Margin="0,4,0,0">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Size:" Opacity="0.6" Margin="0,0,8,4"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FileSize}" Margin="0,0,16,4"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Duration:" Opacity="0.6" Margin="0,0,8,4"/>
                <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding Duration}" Margin="0,0,0,4"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Resolution:" Opacity="0.6" Margin="0,0,8,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Resolution}" Margin="0,0,16,0"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="FPS:" Opacity="0.6" Margin="0,0,8,0"/>
                <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding FrameRate}"/>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
