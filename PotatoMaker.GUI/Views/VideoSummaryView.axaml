<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PotatoMaker.GUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="520" d:DesignHeight="260"
             x:Class="PotatoMaker.GUI.Views.VideoSummaryView"
             x:DataType="vm:VideoSummaryViewModel">

    <Design.DataContext>
        <vm:VideoSummaryViewModel/>
    </Design.DataContext>

    <Border Classes="pm-card"
            Padding="10">
        <StackPanel Spacing="6">
            <TextBlock Text="Video"
                       Classes="pm-section-title"/>

            <Grid ColumnDefinitions="*,*"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="8"
                  ColumnSpacing="8">
                <Border Grid.Row="0"
                        Grid.Column="0"
                        Classes="pm-stat">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Size" Classes="pm-muted"/>
                        <TextBlock Text="{Binding FileSize, TargetNullValue=--}" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="0"
                        Grid.Column="1"
                        Classes="pm-stat">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Duration" Classes="pm-muted"/>
                        <TextBlock Text="{Binding Duration, TargetNullValue=--}" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Grid.Column="0"
                        Classes="pm-stat">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Resolution" Classes="pm-muted"/>
                        <TextBlock Text="{Binding Resolution, TargetNullValue=--}" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Grid.Column="1"
                        Classes="pm-stat">
                    <StackPanel Spacing="2">
                        <TextBlock Text="FPS" Classes="pm-muted"/>
                        <TextBlock Text="{Binding FrameRate, TargetNullValue=--}" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Text="Strategy Preview"
                       Classes="pm-section-title"
                       Margin="0,4,0,0"/>

            <Border Classes="pm-stat">
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding StrategyStatus, TargetNullValue=Waiting for analysis...}"
                               Classes="pm-muted"/>

                    <Grid ColumnDefinitions="*,*"
                          RowDefinitions="Auto,Auto,Auto"
                          RowSpacing="6"
                          ColumnSpacing="8">
                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                            <TextBlock Text="Resolution" Classes="pm-muted"/>
                            <TextBlock Text="{Binding StrategyResolution, TargetNullValue=--}" FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                            <TextBlock Text="Bitrate" Classes="pm-muted"/>
                            <TextBlock Text="{Binding StrategyBitrate, TargetNullValue=--}" FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2">
                            <TextBlock Text="Parts" Classes="pm-muted"/>
                            <TextBlock Text="{Binding StrategyParts, TargetNullValue=--}" FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
                            <TextBlock Text="Crop" Classes="pm-muted"/>
                            <TextBlock Text="{Binding StrategyCrop, TargetNullValue=--}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Spacing="2">
                            <TextBlock Text="FFmpeg filter" Classes="pm-muted"/>
                            <TextBlock Text="{Binding StrategyFilter, TargetNullValue=--}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
