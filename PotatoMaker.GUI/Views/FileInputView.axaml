<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PotatoMaker.GUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="560" d:DesignHeight="120"
             x:Class="PotatoMaker.GUI.Views.FileInputView"
             x:DataType="vm:FileInputViewModel">

    <Design.DataContext>
        <vm:FileInputViewModel/>
    </Design.DataContext>

    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
            BorderThickness="2"
            CornerRadius="8"
            Padding="24"
            Background="Transparent"
            DragDrop.AllowDrop="True"
            x:Name="DropZone">
        <StackPanel HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="&#xE8E5;"
                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                       FontSize="36"
                       HorizontalAlignment="Center"
                       Opacity="0.5"
                       IsVisible="{Binding !HasFile}"/>
            <TextBlock Text="Drag &amp; drop a video file here, or click to browse"
                       HorizontalAlignment="Center"
                       Opacity="0.6"
                       IsVisible="{Binding !HasFile}"/>
            <TextBlock Text="{Binding FileName}"
                       HorizontalAlignment="Center"
                       FontWeight="SemiBold"
                       IsVisible="{Binding HasFile}"/>
            <Button Content="Browse…"
                    Command="{Binding SelectFileCommand}"
                    HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>
