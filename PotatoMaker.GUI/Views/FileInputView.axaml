<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PotatoMaker.GUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="760" d:DesignHeight="150"
             x:Class="PotatoMaker.GUI.Views.FileInputView"
             x:DataType="vm:FileInputViewModel">

    <Design.DataContext>
        <vm:FileInputViewModel/>
    </Design.DataContext>

    <Border x:Name="DropZone"
            Classes="pm-card pm-dropzone"
            Padding="14"
            MinHeight="150"
            DragDrop.AllowDrop="True">
        <Grid RowDefinitions="Auto,Auto,Auto"
              RowSpacing="8">
            <TextBlock Grid.Row="0"
                       Text="Source Video"
                       Classes="pm-section-title"/>

            <Border Grid.Row="1"
                    Background="{DynamicResource PmInsetBackground}"
                    BorderBrush="{DynamicResource PmInsetBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10,8">
                <Grid ColumnDefinitions="Auto,*,24"
                      ColumnSpacing="8"
                      MinHeight="24">
                    <TextBlock Grid.Column="0"
                               Text="File:"
                               Classes="pm-muted"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding FileName, TargetNullValue=No file selected yet}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="2"
                            Content="X"
                            Command="{Binding ClearFileCommand}"
                            IsVisible="{Binding HasFile}"
                            Width="24"
                            Height="24"
                            MinWidth="24"
                            MinHeight="24"
                            Padding="0"
                            FontWeight="Bold"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            ToolTip.Tip="Remove selected file"/>
                </Grid>
            </Border>

            <Grid Grid.Row="2"
                  ColumnDefinitions="Auto,*"
                  ColumnSpacing="10">
                <Button Grid.Column="0"
                        Content="Browse"
                        Command="{Binding SelectFileCommand}"
                        Classes="pm-primary"/>
                <TextBlock Grid.Column="1"
                           Text="Drop to replace. Supported: mp4, mkv, avi, mov, webm, wmv, flv"
                           VerticalAlignment="Center"
                           Classes="pm-muted"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
