<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PotatoMaker.GUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="520" d:DesignHeight="116"
             x:Class="PotatoMaker.GUI.Views.FileInputView"
             x:DataType="vm:FileInputViewModel">

    <Design.DataContext>
        <vm:FileInputViewModel/>
    </Design.DataContext>

    <Border x:Name="DropZone"
            Classes="pm-card pm-dropzone"
            Padding="8"
            MinHeight="92"
            DragDrop.AllowDrop="True">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto"
              RowSpacing="4">
            <TextBlock Grid.Row="0"
                       Text="Source Video"
                       Classes="pm-section-title"/>

            <Border Grid.Row="1"
                    Classes="pm-inset">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="6"
                      MinHeight="24">
                    <TextBlock Grid.Column="0"
                               Text="File:"
                               Classes="pm-caption"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding FileName, TargetNullValue=No file selected yet}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               Margin="2,0,0,0"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="2"
                            Content="x"
                            Command="{Binding ClearFileCommand}"
                            IsVisible="{Binding HasFile}"
                            Width="22"
                            Height="22"
                            MinWidth="22"
                            MinHeight="22"
                            Padding="0"
                            FontWeight="Bold"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            ToolTip.Tip="Remove selected file"/>
                </Grid>
            </Border>

            <Grid Grid.Row="2"
                  ColumnDefinitions="Auto,*"
                  ColumnSpacing="6">
                <Button Grid.Column="0"
                        Content="Browse..."
                        Command="{Binding SelectFileCommand}"
                        Classes="pm-primary"/>
                <TextBlock Grid.Column="1"
                           Text="Drag and drop a video here, or browse."
                           VerticalAlignment="Center"
                           Classes="pm-caption"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>

            <TextBlock Grid.Row="3"
                       Text="{Binding ValidationMessage}"
                       IsVisible="{Binding HasValidationMessage}"
                       Foreground="{DynamicResource PmErrorForeground}"
                       FontSize="11"
                       TextWrapping="Wrap"/>
        </Grid>
    </Border>
</UserControl>
