<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PotatoMaker.GUI.ViewModels"
             xmlns:views="using:PotatoMaker.GUI.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="920" d:DesignHeight="720"
             x:Class="PotatoMaker.GUI.Views.MainWorkspaceView"
             x:DataType="vm:EncodeWorkspaceViewModel">

    <Design.DataContext>
        <vm:EncodeWorkspaceViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="*,320"
          RowDefinitions="1.95*,0.82*,Auto"
          RowSpacing="12"
          ColumnSpacing="12">
        <views:VideoPlayerView Grid.Column="0"
                               Grid.Row="0"
                               DataContext="{Binding}"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch"/>

        <ContentControl Grid.Column="0"
                        Grid.Row="1"
                        Grid.RowSpan="2"
                        Content="{Binding ConversionLog}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"/>

        <ContentControl Grid.Column="1"
                        Grid.Row="0"
                        Content="{Binding VideoSummary}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"/>

        <ContentControl Grid.Column="1"
                        Grid.Row="1"
                        Content="{Binding OutputSettings}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"/>

        <Button Grid.Column="1"
                Grid.Row="2"
                Content="{Binding EncodeButtonText}"
                Command="{Binding EncodeButtonCommand}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Bottom"
                MinHeight="34"
                Padding="10,6"
                Classes.pm-primary="{Binding IsEncodeIdle}"
                Classes.pm-cancel="{Binding IsEncodeInProgress}"/>
    </Grid>
</UserControl>
