<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PotatoMaker.GUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="520" d:DesignHeight="270"
             x:Class="PotatoMaker.GUI.Views.ClipRangeView"
             x:DataType="vm:ClipRangeViewModel">

    <Design.DataContext>
        <vm:ClipRangeViewModel/>
    </Design.DataContext>

    <Border Classes="pm-card"
            Padding="8"
            MinHeight="250">
        <StackPanel Spacing="6">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
                <StackPanel Grid.Column="0"
                            Spacing="2">
                    <TextBlock Text="Clip Range"
                               Classes="pm-section-title"/>
                    <TextBlock Text="Choose which section should be analyzed and encoded."
                               Classes="pm-caption"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Reset"
                        Command="{Binding ResetSelectionCommand}"
                        IsEnabled="{Binding CanResetSelection}"
                        VerticalAlignment="Top"/>
            </Grid>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="8"
                  IsEnabled="{Binding HasDuration}">
                <Border Grid.Column="0"
                        Classes="pm-inset"
                        Padding="6">
                    <Grid RowDefinitions="Auto,Auto,64"
                          RowSpacing="4">
                        <TextBlock Grid.Row="0"
                                   Text="Start frame"
                                   Classes="pm-caption"/>
                        <TextBlock Grid.Row="1"
                                   Text="{Binding StartDisplay}"
                                   FontWeight="SemiBold"/>
                        <Grid Grid.Row="2"
                              Height="64">
                            <Image Source="{Binding StartPreviewImage}"
                                   Stretch="UniformToFill"
                                   Height="64"
                                   IsVisible="{Binding HasStartPreview}"/>
                            <TextBlock Text="{Binding StartPreviewMessage}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       IsVisible="{Binding !HasStartPreview}"/>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Classes="pm-inset"
                        Padding="6">
                    <Grid RowDefinitions="Auto,Auto,64"
                          RowSpacing="4">
                        <TextBlock Grid.Row="0"
                                   Text="End frame"
                                   Classes="pm-caption"/>
                        <TextBlock Grid.Row="1"
                                   Text="{Binding EndDisplay}"
                                   FontWeight="SemiBold"/>
                        <Grid Grid.Row="2"
                              Height="64">
                            <Image Source="{Binding EndPreviewImage}"
                                   Stretch="UniformToFill"
                                   Height="64"
                                   IsVisible="{Binding HasEndPreview}"/>
                            <TextBlock Text="{Binding EndPreviewMessage}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       IsVisible="{Binding !HasEndPreview}"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <StackPanel Spacing="4"
                        IsEnabled="{Binding HasDuration}">
                <StackPanel Spacing="2">
                    <TextBlock Text="Start point" Classes="pm-caption"/>
                    <Slider x:Name="StartSlider"
                            Minimum="0"
                            Maximum="{Binding MaximumSeconds}"
                            Value="{Binding StartSeconds}"/>
                </StackPanel>

                <StackPanel Spacing="2">
                    <TextBlock Text="End point" Classes="pm-caption"/>
                    <Slider x:Name="EndSlider"
                            Minimum="0"
                            Maximum="{Binding MaximumSeconds}"
                            Value="{Binding EndSeconds}"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
