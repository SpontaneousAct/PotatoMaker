<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PotatoMaker.GUI.ViewModels"
             xmlns:vlc="using:LibVLCSharp.Avalonia"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="520" d:DesignHeight="430"
             x:Class="PotatoMaker.GUI.Views.VideoPlayerView"
             x:DataType="vm:EncodeWorkspaceViewModel">

    <Design.DataContext>
        <vm:EncodeWorkspaceViewModel/>
    </Design.DataContext>

    <Border x:Name="PlayerDropZone"
            Classes="pm-card pm-dropzone"
            Padding="8"
            DragDrop.AllowDrop="True">
        <Grid RowDefinitions="Auto,Auto,*,Auto,Auto"
              RowSpacing="6">
            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto,Auto,Auto,28"
                  ColumnSpacing="8">
                <StackPanel Grid.Column="0"
                            Spacing="0">
                    <TextBlock Text="Video Preview"
                               Classes="pm-section-title"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Spacing="1"
                            MinWidth="72">
                    <TextBlock Text="Start"
                               Classes="pm-caption"/>
                    <TextBlock Text="{Binding ClipRange.StartDisplay}"
                               FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Spacing="1"
                            MinWidth="72">
                    <TextBlock Text="End"
                               Classes="pm-caption"/>
                    <TextBlock Text="{Binding ClipRange.EndDisplay}"
                               FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="3"
                            Spacing="1"
                            MinWidth="72">
                    <TextBlock Text="Length"
                               Classes="pm-caption"/>
                    <TextBlock Text="{Binding ClipRange.SelectedDurationDisplay}"
                               FontWeight="SemiBold"/>
                </StackPanel>

                <Button Grid.Column="4"
                        Content="X"
                        Command="{Binding FileInput.ClearFileCommand}"
                        IsVisible="{Binding FileInput.HasFile}"
                        Width="28"
                        Height="28"
                        MinWidth="28"
                        MinHeight="28"
                        Padding="0"
                        FontWeight="Bold"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        ToolTip.Tip="Remove selected file"/>
            </Grid>

            <TextBlock Grid.Row="1"
                       Text="{Binding FileInput.ValidationMessage}"
                       IsVisible="{Binding FileInput.HasValidationMessage}"
                       Foreground="{DynamicResource PmErrorForeground}"
                       FontSize="11"
                       TextWrapping="Wrap"/>

            <Border Grid.Row="2"
                    Classes="pm-video-surface"
                    CornerRadius="0"
                    MinHeight="180">
                <Grid>
                    <vlc:VideoView MediaPlayer="{Binding VideoPlayer.MediaPlayer}"
                                   IsVisible="{Binding VideoPlayer.IsVideoSurfaceVisible}"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"/>

                    <StackPanel IsVisible="{Binding VideoPlayer.HasPlayerError}"
                                Spacing="6"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="280"
                                Margin="16">
                        <TextBlock Text="{Binding VideoPlayer.PlayerErrorMessage}"
                                   Foreground="{DynamicResource PmErrorForeground}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding VideoPlayer.HasPlayerError}"/>
                    </StackPanel>

                    <Border IsVisible="{Binding FileInput.HasNoFile}"
                            Background="{DynamicResource PmVideoEmptyBackground}">
                        <StackPanel Spacing="12"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    MaxWidth="320"
                                    Margin="20">
                            <TextBlock Text="Drop a video here to preview it."
                                       Classes="pm-section-title"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="Browse for a source file or drag and drop one anywhere on this card."
                                       Classes="pm-caption"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"/>
                            <Button Content="Browse..."
                                    Command="{Binding FileInput.SelectFileCommand}"
                                    Classes="pm-primary"
                                    HorizontalAlignment="Center"
                                    MinWidth="140"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <StackPanel Grid.Row="3"
                        Spacing="3">
                <Canvas x:Name="PlaybackTimelineCanvas"
                        Height="46"
                        ClipToBounds="False"
                        Background="Transparent"
                        Cursor="Hand"
                        IsEnabled="{Binding VideoPlayer.CanSeek}">
                    <Border x:Name="TimelineTrackBackground"
                            Height="4"
                            CornerRadius="2"
                            Background="{DynamicResource PmCardBorderBrush}"
                            Canvas.Top="26"/>
                    <Border x:Name="TrimRangeBar"
                            Height="10"
                            CornerRadius="5"
                            Background="{DynamicResource PmTrimRangeBackground}"
                            Opacity="0.26"
                            Canvas.Top="23"/>
                    <Border x:Name="TimelineProgressBar"
                            Height="4"
                            CornerRadius="2"
                            Background="{DynamicResource PmPrimaryBackground}"
                            Canvas.Top="26"/>
                    <Border x:Name="TrimStartStem"
                            Width="3"
                            Height="14"
                            CornerRadius="1.5"
                            Background="{DynamicResource PmTrimStartBackground}"
                            Canvas.Top="14"/>
                    <Border x:Name="TrimEndStem"
                            Width="3"
                            Height="14"
                            CornerRadius="1.5"
                            Background="{DynamicResource PmCancelBackground}"
                            Canvas.Top="14"/>
                    <Border x:Name="TrimStartHandle"
                            Width="20"
                            Height="20"
                            CornerRadius="10"
                            Background="{DynamicResource PmTrimStartBackground}"
                            BorderBrush="{DynamicResource PmCardBackground}"
                            BorderThickness="2"
                            Cursor="Hand"
                            Canvas.Top="0">
                        <TextBlock Text="S"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="10"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="TrimEndHandle"
                            Width="20"
                            Height="20"
                            CornerRadius="10"
                            Background="{DynamicResource PmCancelBackground}"
                            BorderBrush="{DynamicResource PmCardBackground}"
                            BorderThickness="2"
                            Cursor="Hand"
                            Canvas.Top="0">
                        <TextBlock Text="E"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="10"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="TimelineThumb"
                            Width="18"
                            Height="18"
                            CornerRadius="9"
                            Background="{DynamicResource PmPrimaryBackground}"
                            BorderBrush="{DynamicResource PmCardBackground}"
                            BorderThickness="2"
                            Cursor="Hand"
                            Canvas.Top="19"/>
                </Canvas>

                <Grid ColumnDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="{Binding VideoPlayer.CurrentTimeDisplay}"
                               Classes="pm-caption"/>
                    <TextBlock Grid.Column="2"
                               Text="{Binding VideoPlayer.DurationDisplay}"
                               Classes="pm-caption"
                               HorizontalAlignment="Right"/>
                </Grid>
            </StackPanel>

            <Grid Grid.Row="4"
                  ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,96,*"
                  ColumnSpacing="4">
                <Button Grid.Column="0"
                        Content="{Binding VideoPlayer.TogglePlaybackText}"
                        Command="{Binding VideoPlayer.TogglePlaybackCommand}"
                        MinWidth="84"
                        MinHeight="28"
                        Padding="9,4"
                        Classes.pm-primary="{Binding VideoPlayer.CanControlPlayback}"/>

                <Button Grid.Column="1"
                        Content="Reset"
                        Command="{Binding ResetPreviewCommand}"
                        MinHeight="28"
                        Padding="9,4"/>

                <Button Grid.Column="2"
                        Content="Set Start"
                        Command="{Binding VideoPlayer.SetTrimStartCommand}"
                        MinHeight="28"
                        Padding="9,4"/>

                <Button Grid.Column="3"
                        Content="Set End"
                        Command="{Binding VideoPlayer.SetTrimEndCommand}"
                        MinHeight="28"
                        Padding="9,4"/>

                <Button Grid.Column="4"
                        Content="{Binding VideoPlayer.ToggleMuteText}"
                        Command="{Binding VideoPlayer.ToggleMuteCommand}"
                        IsEnabled="{Binding VideoPlayer.CanAdjustVolume}"
                        Width="78"
                        MinHeight="28"
                        Padding="9,4"/>

                <Slider Grid.Column="5"
                        Minimum="0"
                        Maximum="100"
                        Value="{Binding VideoPlayer.VolumePercent}"
                        IsEnabled="{Binding VideoPlayer.CanAdjustVolume}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Stretch"
                        MinWidth="72"/>

            </Grid>
        </Grid>
    </Border>
</UserControl>
