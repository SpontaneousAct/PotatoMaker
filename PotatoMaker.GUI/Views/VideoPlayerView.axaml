<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PotatoMaker.GUI.ViewModels"
             xmlns:vlc="using:LibVLCSharp.Avalonia"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="520" d:DesignHeight="430"
             x:Class="PotatoMaker.GUI.Views.VideoPlayerView"
             x:DataType="vm:EncodeWorkspaceViewModel">

    <Design.DataContext>
        <vm:EncodeWorkspaceViewModel/>
    </Design.DataContext>

    <Border x:Name="PlayerDropZone"
            Classes="pm-card pm-dropzone"
            Padding="8"
            DragDrop.AllowDrop="True">
        <Grid RowDefinitions="Auto,Auto,*,Auto,Auto"
              RowSpacing="6">
            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto,Auto,Auto,28"
                  ColumnSpacing="8">
                <StackPanel Grid.Column="0"
                            Spacing="0">
                    <TextBlock Text="Video Preview"
                               Classes="pm-section-title"/>
                    <TextBlock Text="{Binding FileInput.FileName}"
                               IsVisible="{Binding FileInput.HasFile}"
                               Classes="pm-caption"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Spacing="1"
                            MinWidth="72">
                    <TextBlock Text="Start"
                               Classes="pm-caption"/>
                    <TextBlock Text="{Binding ClipRange.StartDisplay}"
                               FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Spacing="1"
                            MinWidth="72">
                    <TextBlock Text="End"
                               Classes="pm-caption"/>
                    <TextBlock Text="{Binding ClipRange.EndDisplay}"
                               FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="3"
                            Spacing="1"
                            MinWidth="72">
                    <TextBlock Text="Length"
                               Classes="pm-caption"/>
                    <TextBlock Text="{Binding ClipRange.SelectedDurationDisplay}"
                               FontWeight="SemiBold"/>
                </StackPanel>

                <Button Grid.Column="4"
                        Command="{Binding FileInput.ClearFileCommand}"
                        IsVisible="{Binding FileInput.HasFile}"
                        Width="28"
                        Height="28"
                        MinWidth="28"
                        MinHeight="28"
                        Padding="0"
                        FontWeight="Bold"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        ToolTip.Tip="Remove selected file">
                    <Grid Width="12"
                          Height="12"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                        <Path Data="{StaticResource PmIconDismissGeometry}"
                              Width="12"
                              Height="12"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Fill="{DynamicResource PmSectionTitleForeground}"/>
                    </Grid>
                </Button>
            </Grid>

            <TextBlock Grid.Row="1"
                       Text="{Binding FileInput.ValidationMessage}"
                       IsVisible="{Binding FileInput.HasValidationMessage}"
                       Foreground="{DynamicResource PmErrorForeground}"
                       FontSize="11"
                       TextWrapping="Wrap"/>

            <Border Grid.Row="2"
                    Classes="pm-video-surface"
                    CornerRadius="0"
                    MinHeight="180">
                <Grid>
                    <vlc:VideoView MediaPlayer="{Binding VideoPlayer.MediaPlayer}"
                                   IsVisible="{Binding VideoPlayer.IsVideoSurfaceVisible}"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"/>

                    <StackPanel IsVisible="{Binding VideoPlayer.ShowStatusMessage}"
                                Spacing="6"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="280"
                                Margin="16">
                        <TextBlock Text="{Binding VideoPlayer.StatusMessage}"
                                   Classes="pm-caption"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding VideoPlayer.HasPlayerError}"
                                Spacing="6"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="280"
                                Margin="16">
                        <TextBlock Text="{Binding VideoPlayer.PlayerErrorMessage}"
                                   Foreground="{DynamicResource PmErrorForeground}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding VideoPlayer.HasPlayerError}"/>
                    </StackPanel>

                    <Border IsVisible="{Binding FileInput.HasNoFile}"
                            Background="{DynamicResource PmVideoEmptyBackground}">
                        <StackPanel Spacing="12"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    MaxWidth="320"
                                    Margin="20">
                            <TextBlock Text="Drop a video here to preview it."
                                       Classes="pm-section-title"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="Browse for a source file or drag and drop one anywhere on this card."
                                       Classes="pm-caption"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"/>
                            <Button Content="Browse..."
                                    Command="{Binding FileInput.SelectFileCommand}"
                                    Classes="pm-primary"
                                    HorizontalAlignment="Center"
                                    MinWidth="140"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <StackPanel Grid.Row="3"
                        Spacing="3">
                <Canvas x:Name="PlaybackTimelineCanvas"
                        Height="52"
                        ClipToBounds="False"
                        Background="Transparent"
                        Cursor="Hand"
                        IsEnabled="{Binding VideoPlayer.CanSeek}">
                    <Border x:Name="TimelineTrackBackground"
                            Height="6"
                            CornerRadius="2"
                            Background="{DynamicResource PmCardBorderBrush}"
                            Canvas.Top="30"/>
                    <Border x:Name="TrimRangeBar"
                            Height="16"
                            CornerRadius="8"
                            Background="{DynamicResource PmTrimRangeBackground}"
                            Opacity="0.26"
                            Canvas.Top="25"/>
                    <Border x:Name="TimelineProgressBar"
                            Height="6"
                            CornerRadius="2"
                            Background="{DynamicResource PmPrimaryBackground}"
                            Canvas.Top="30"/>
                    <Border x:Name="TrimStartStem"
                            Width="3"
                            Height="18"
                            CornerRadius="1.5"
                            Background="{DynamicResource PmTrimStartBackground}"
                            Canvas.Top="12"/>
                    <Border x:Name="TrimEndStem"
                            Width="3"
                            Height="18"
                            CornerRadius="1.5"
                            Background="{DynamicResource PmCancelBackground}"
                            Canvas.Top="12"/>
                    <Border x:Name="TrimStartHandle"
                            Width="24"
                            Height="24"
                            CornerRadius="12"
                            Background="{DynamicResource PmTrimStartBackground}"
                            BorderBrush="{DynamicResource PmCardBackground}"
                            BorderThickness="2"
                            Cursor="Hand"
                            Canvas.Top="0">
                        <TextBlock Text="S"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="TrimEndHandle"
                            Width="24"
                            Height="24"
                            CornerRadius="12"
                            Background="{DynamicResource PmCancelBackground}"
                            BorderBrush="{DynamicResource PmCardBackground}"
                            BorderThickness="2"
                            Cursor="Hand"
                            Canvas.Top="0">
                        <TextBlock Text="E"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="TimelineThumb"
                            Width="22"
                            Height="22"
                            CornerRadius="11"
                            Background="{DynamicResource PmPrimaryBackground}"
                            BorderBrush="{DynamicResource PmCardBackground}"
                            BorderThickness="2"
                            Cursor="Hand"
                            Canvas.Top="22"/>
                </Canvas>

                <Grid ColumnDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="{Binding VideoPlayer.CurrentTimeDisplay}"
                               Classes="pm-caption"/>
                    <TextBlock Grid.Column="2"
                               Text="{Binding VideoPlayer.DurationDisplay}"
                               Classes="pm-caption"
                               HorizontalAlignment="Right"/>
                </Grid>
            </StackPanel>

            <Grid Grid.Row="4"
                  ColumnDefinitions="*,Auto,*"
                  Margin="0,8,0,0">
                <Border Grid.Column="1"
                        Classes="pm-control-cluster"
                        HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                Spacing="6"
                                VerticalAlignment="Center">
                        <Button Classes="pm-control-pill"
                                Content="Set Start"
                                Command="{Binding VideoPlayer.SetTrimStartCommand}"
                                ToolTip.Tip="Set trim start to the current playback position"/>

                        <Button Classes="pm-player-action"
                                Command="{Binding VideoPlayer.SeekBackwardTenSecondsCommand}"
                                ToolTip.Tip="Back 10 seconds">
                            <Viewbox Width="18"
                                     Height="18"
                                     Stretch="Uniform"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Path Classes="pm-control-icon"
                                      Data="{StaticResource PmIconSkipBack10Geometry}"/>
                            </Viewbox>
                        </Button>

                        <Button Classes="pm-player-action pm-primary"
                                Classes.is-playing="{Binding VideoPlayer.IsPlaying}"
                                Command="{Binding VideoPlayer.TogglePlaybackCommand}"
                                ToolTip.Tip="{Binding VideoPlayer.TogglePlaybackText}">
                            <Grid Width="14"
                                  Height="14"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center">
                                <Path Classes="pm-control-icon pm-icon-play"
                                      Data="{StaticResource PmIconPlayGeometry}"/>
                                <Path Classes="pm-control-icon pm-icon-pause"
                                      Data="{StaticResource PmIconPauseGeometry}"/>
                            </Grid>
                        </Button>

                        <Button Classes="pm-player-action pm-cancel"
                                Command="{Binding ResetPreviewCommand}"
                                ToolTip.Tip="Stop and reset preview">
                            <Viewbox Width="10"
                                     Height="10"
                                     Stretch="Uniform"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Path Classes="pm-control-icon"
                                      Data="{StaticResource PmIconStopGeometry}"/>
                            </Viewbox>
                        </Button>

                        <Button Classes="pm-player-action"
                                Command="{Binding VideoPlayer.SeekForwardTenSecondsCommand}"
                                ToolTip.Tip="Forward 10 seconds">
                            <Viewbox Width="18"
                                     Height="18"
                                     Stretch="Uniform"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Path Classes="pm-control-icon"
                                      Data="{StaticResource PmIconSkipForward10Geometry}"/>
                            </Viewbox>
                        </Button>

                        <Button Classes="pm-control-pill"
                                Content="Set End"
                                Command="{Binding VideoPlayer.SetTrimEndCommand}"
                                ToolTip.Tip="Set trim end to the current playback position"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Classes="pm-audio-cluster"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                Spacing="6"
                                VerticalAlignment="Center">
                        <Button Classes="pm-player-action pm-audio-action"
                                Classes.is-muted="{Binding VideoPlayer.IsMuted}"
                                Command="{Binding VideoPlayer.ToggleMuteCommand}"
                                IsEnabled="{Binding VideoPlayer.CanAdjustVolume}"
                                ToolTip.Tip="{Binding VideoPlayer.ToggleMuteText}">
                            <Viewbox Width="14"
                                     Height="12"
                                     Stretch="Uniform"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Grid Width="14"
                                      Height="12">
                                    <Path Classes="pm-control-icon pm-icon-unmuted"
                                          Data="{StaticResource PmIconSpeakerGeometry}"/>
                                    <Path Classes="pm-control-icon pm-icon-muted"
                                          Data="{StaticResource PmIconSpeakerOffGeometry}"/>
                                </Grid>
                            </Viewbox>
                        </Button>

                        <Slider Classes="pm-audio-slider"
                                Minimum="0"
                                Maximum="100"
                                Value="{Binding VideoPlayer.VolumePercent}"
                                IsEnabled="{Binding VideoPlayer.CanAdjustVolume}"
                                VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
