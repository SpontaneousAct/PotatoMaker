<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PotatoMaker.GUI.ViewModels"
             xmlns:vlc="using:LibVLCSharp.Avalonia"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="520" d:DesignHeight="430"
             x:Class="PotatoMaker.GUI.Views.VideoPlayerView"
             x:DataType="vm:EncodeWorkspaceViewModel">

    <Design.DataContext>
        <vm:EncodeWorkspaceViewModel/>
    </Design.DataContext>

    <Border x:Name="PlayerDropZone"
            Classes="pm-card pm-dropzone"
            Padding="8"
            DragDrop.AllowDrop="True">
        <Grid RowDefinitions="Auto,Auto,*,Auto,Auto"
              RowSpacing="6">
            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto,Auto,Auto,28"
                  ColumnSpacing="8">
                <StackPanel Grid.Column="0"
                            Spacing="0">
                    <TextBlock Text="Video Preview"
                               Classes="pm-section-title"/>
                    <TextBlock Text="{Binding FileInput.FileName}"
                               IsVisible="{Binding FileInput.HasFile}"
                               Classes="pm-caption"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Spacing="1"
                            MinWidth="72">
                    <TextBlock Text="Start"
                               Classes="pm-caption"/>
                    <TextBlock Text="{Binding ClipRange.StartDisplay}"
                               FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Spacing="1"
                            MinWidth="72">
                    <TextBlock Text="End"
                               Classes="pm-caption"/>
                    <TextBlock Text="{Binding ClipRange.EndDisplay}"
                               FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="3"
                            Spacing="1"
                            MinWidth="72">
                    <TextBlock Text="Length"
                               Classes="pm-caption"/>
                    <TextBlock Text="{Binding ClipRange.SelectedDurationDisplay}"
                               FontWeight="SemiBold"/>
                </StackPanel>

                <Button Grid.Column="4"
                        Content="X"
                        Command="{Binding FileInput.ClearFileCommand}"
                        IsVisible="{Binding FileInput.HasFile}"
                        Width="28"
                        Height="28"
                        MinWidth="28"
                        MinHeight="28"
                        Padding="0"
                        FontWeight="Bold"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        ToolTip.Tip="Remove selected file"/>
            </Grid>

            <TextBlock Grid.Row="1"
                       Text="{Binding FileInput.ValidationMessage}"
                       IsVisible="{Binding FileInput.HasValidationMessage}"
                       Foreground="{DynamicResource PmErrorForeground}"
                       FontSize="11"
                       TextWrapping="Wrap"/>

            <Border Grid.Row="2"
                    Classes="pm-video-surface"
                    CornerRadius="0"
                    MinHeight="180">
                <Grid>
                    <vlc:VideoView MediaPlayer="{Binding VideoPlayer.MediaPlayer}"
                                   IsVisible="{Binding VideoPlayer.IsVideoSurfaceVisible}"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"/>

                    <StackPanel IsVisible="{Binding VideoPlayer.ShowStatusMessage}"
                                Spacing="6"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="280"
                                Margin="16">
                        <TextBlock Text="{Binding VideoPlayer.StatusMessage}"
                                   Classes="pm-caption"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding VideoPlayer.HasPlayerError}"
                                Spacing="6"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="280"
                                Margin="16">
                        <TextBlock Text="{Binding VideoPlayer.PlayerErrorMessage}"
                                   Foreground="{DynamicResource PmErrorForeground}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding VideoPlayer.HasPlayerError}"/>
                    </StackPanel>

                    <Border IsVisible="{Binding FileInput.HasNoFile}"
                            Background="{DynamicResource PmVideoEmptyBackground}">
                        <StackPanel Spacing="12"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    MaxWidth="320"
                                    Margin="20">
                            <TextBlock Text="Drop a video here to preview it."
                                       Classes="pm-section-title"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="Browse for a source file or drag and drop one anywhere on this card."
                                       Classes="pm-caption"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"/>
                            <Button Content="Browse..."
                                    Command="{Binding FileInput.SelectFileCommand}"
                                    Classes="pm-primary"
                                    HorizontalAlignment="Center"
                                    MinWidth="140"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <StackPanel Grid.Row="3"
                        Spacing="3">
                <Canvas x:Name="PlaybackTimelineCanvas"
                        Height="52"
                        ClipToBounds="False"
                        Background="Transparent"
                        Cursor="Hand"
                        IsEnabled="{Binding VideoPlayer.CanSeek}">
                    <Border x:Name="TimelineTrackBackground"
                            Height="6"
                            CornerRadius="2"
                            Background="{DynamicResource PmCardBorderBrush}"
                            Canvas.Top="30"/>
                    <Border x:Name="TrimRangeBar"
                            Height="16"
                            CornerRadius="8"
                            Background="{DynamicResource PmTrimRangeBackground}"
                            Opacity="0.26"
                            Canvas.Top="25"/>
                    <Border x:Name="TimelineProgressBar"
                            Height="6"
                            CornerRadius="2"
                            Background="{DynamicResource PmPrimaryBackground}"
                            Canvas.Top="30"/>
                    <Border x:Name="TrimStartStem"
                            Width="3"
                            Height="18"
                            CornerRadius="1.5"
                            Background="{DynamicResource PmTrimStartBackground}"
                            Canvas.Top="12"/>
                    <Border x:Name="TrimEndStem"
                            Width="3"
                            Height="18"
                            CornerRadius="1.5"
                            Background="{DynamicResource PmCancelBackground}"
                            Canvas.Top="12"/>
                    <Border x:Name="TrimStartHandle"
                            Width="24"
                            Height="24"
                            CornerRadius="12"
                            Background="{DynamicResource PmTrimStartBackground}"
                            BorderBrush="{DynamicResource PmCardBackground}"
                            BorderThickness="2"
                            Cursor="Hand"
                            Canvas.Top="0">
                        <TextBlock Text="S"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="TrimEndHandle"
                            Width="24"
                            Height="24"
                            CornerRadius="12"
                            Background="{DynamicResource PmCancelBackground}"
                            BorderBrush="{DynamicResource PmCardBackground}"
                            BorderThickness="2"
                            Cursor="Hand"
                            Canvas.Top="0">
                        <TextBlock Text="E"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="TimelineThumb"
                            Width="22"
                            Height="22"
                            CornerRadius="11"
                            Background="{DynamicResource PmPrimaryBackground}"
                            BorderBrush="{DynamicResource PmCardBackground}"
                            BorderThickness="2"
                            Cursor="Hand"
                            Canvas.Top="22"/>
                </Canvas>

                <Grid ColumnDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="{Binding VideoPlayer.CurrentTimeDisplay}"
                               Classes="pm-caption"/>
                    <TextBlock Grid.Column="2"
                               Text="{Binding VideoPlayer.DurationDisplay}"
                               Classes="pm-caption"
                               HorizontalAlignment="Right"/>
                </Grid>
            </StackPanel>

            <Grid Grid.Row="4"
                  ColumnDefinitions="*,Auto,*"
                  Margin="0,8,0,0">
                <Border Grid.Column="1"
                        Classes="pm-control-cluster"
                        HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                Spacing="6"
                                VerticalAlignment="Center">
                        <Button Classes="pm-control-pill"
                                Content="Set Start"
                                Command="{Binding VideoPlayer.SetTrimStartCommand}"
                                ToolTip.Tip="Set trim start to the current playback position"/>

                        <Button Classes="pm-player-action"
                                Command="{Binding VideoPlayer.SeekBackwardTenSecondsCommand}"
                                ToolTip.Tip="Back 10 seconds">
                            <Viewbox Width="18"
                                     Height="18"
                                     Stretch="Uniform"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Path Classes="pm-control-icon"
                                      Data="M2.998 3.5c0-0.276 0.224-0.5 0.5-0.5s0.5 0.224 0.5 0.5v2.206c0.913-1.034 2.084-1.822 3.406-2.275 1.837-0.629 3.839-0.568 5.634 0.17 1.794 0.74 3.26 2.106 4.121 3.845 0.123 0.247 0.022 0.547-0.226 0.67-0.247 0.122-0.547 0.021-0.67-0.226-0.754-1.522-2.036-2.717-3.606-3.363-1.57-0.647-3.322-0.7-4.929-0.15C6.315 4.861 5.1 5.782 4.252 7h3.246c0.276 0 0.5 0.224 0.5 0.5S7.774 8 7.498 8h-4c-0.276 0-0.5-0.224-0.5-0.5v-4zM8 10.5c0-0.184-0.101-0.354-0.264-0.44-0.163-0.088-0.36-0.078-0.513 0.024l-1.5 1c-0.23 0.153-0.292 0.464-0.139 0.693 0.153 0.23 0.464 0.292 0.693 0.139L7 11.434V16.5C7 16.776 7.224 17 7.5 17S8 16.776 8 16.5v-6zm4.503-0.5c-0.935 0-1.597 0.437-1.996 1.13-0.376 0.653-0.504 1.507-0.504 2.37 0 0.863 0.128 1.717 0.504 2.37 0.399 0.693 1.061 1.13 1.996 1.13s1.597-0.437 1.996-1.13c0.376-0.653 0.504-1.507 0.504-2.37 0-0.863-0.128-1.717-0.504-2.37C14.1 10.436 13.438 10 12.503 10zm-1.5 3.5c0-0.793 0.122-1.44 0.37-1.872C11.6 11.235 11.939 11 12.504 11s0.903 0.235 1.13 0.628c0.248 0.432 0.37 1.079 0.37 1.872 0 0.793-0.122 1.44-0.37 1.872C13.405 15.765 13.067 16 12.502 16s-0.903-0.235-1.13-0.628c-0.248-0.432-0.37-1.079-0.37-1.872z"/>
                            </Viewbox>
                        </Button>

                        <Button Classes="pm-player-action pm-primary"
                                Classes.is-playing="{Binding VideoPlayer.IsPlaying}"
                                Command="{Binding VideoPlayer.TogglePlaybackCommand}"
                                ToolTip.Tip="{Binding VideoPlayer.TogglePlaybackText}">
                            <Grid Width="14"
                                  Height="14"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center">
                                <TextBlock Classes="pm-control-symbol pm-icon-play-glyph"
                                           FontSize="12"
                                           Text="&#xE768;"
                                           Width="14"
                                           Height="14"
                                           LineHeight="14"/>
                                <TextBlock Classes="pm-control-symbol pm-icon-pause-glyph"
                                           FontSize="12"
                                           Text="&#xE769;"
                                           Width="14"
                                           Height="14"
                                           LineHeight="14"/>
                            </Grid>
                        </Button>

                        <Button Classes="pm-player-action pm-cancel"
                                Command="{Binding ResetPreviewCommand}"
                                ToolTip.Tip="Stop and reset preview">
                            <Viewbox Width="10"
                                     Height="10"
                                     Stretch="Uniform"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Path Classes="pm-control-icon"
                                      Data="M 1 1 H 9 V 9 H 1 Z"/>
                            </Viewbox>
                        </Button>

                        <Button Classes="pm-player-action"
                                Command="{Binding VideoPlayer.SeekForwardTenSecondsCommand}"
                                ToolTip.Tip="Forward 10 seconds">
                            <Viewbox Width="18"
                                     Height="18"
                                     Stretch="Uniform"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Path Classes="pm-control-icon"
                                      Data="M16.999 3.5c0-0.276-0.224-0.5-0.5-0.5s-0.5 0.224-0.5 0.5v2.202c-0.912-1.032-2.082-1.819-3.403-2.27-1.836-0.63-3.838-0.569-5.633 0.17C5.168 4.34 3.703 5.707 2.84 7.446c-0.122 0.246-0.02 0.546 0.227 0.67 0.248 0.122 0.547 0.021 0.67-0.226 0.754-1.522 2.036-2.717 3.606-3.363 1.57-0.647 3.322-0.7 4.93-0.15C13.684 4.861 14.9 5.782 15.748 7h-3.25c-0.276 0-0.5 0.224-0.5 0.5s0.224 0.5 0.5 0.5h4c0.276 0 0.5-0.224 0.5-0.5v-4zm-6.493 7.63c0.399-0.693 1.061-1.13 1.996-1.13s1.597 0.437 1.996 1.13c0.376 0.653 0.504 1.507 0.504 2.37 0 0.863-0.128 1.717-0.504 2.37-0.399 0.693-1.061 1.13-1.996 1.13s-1.597-0.437-1.996-1.13c-0.376-0.653-0.504-1.507-0.504-2.37 0-0.863 0.128-1.717 0.504-2.37zm0.867 0.498c-0.249 0.432-0.371 1.079-0.371 1.872 0 0.793 0.122 1.44 0.37 1.872C11.6 15.765 11.938 16 12.503 16s0.903-0.235 1.13-0.628c0.248-0.432 0.37-1.079 0.37-1.872 0-0.793-0.122-1.44-0.37-1.872C13.404 11.235 13.066 11 12.501 11s-0.903 0.235-1.13 0.628zM7.999 10.5c0-0.184-0.101-0.354-0.264-0.44-0.163-0.088-0.36-0.078-0.513 0.024l-1.5 1c-0.23 0.153-0.292 0.464-0.139 0.693 0.153 0.23 0.464 0.292 0.693 0.139L7 11.434V16.5C7 16.776 7.223 17 7.5 17S8 16.776 8 16.5v-6z"/>
                            </Viewbox>
                        </Button>

                        <Button Classes="pm-control-pill"
                                Content="Set End"
                                Command="{Binding VideoPlayer.SetTrimEndCommand}"
                                ToolTip.Tip="Set trim end to the current playback position"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Classes="pm-audio-cluster"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                Spacing="6"
                                VerticalAlignment="Center">
                        <Button Classes="pm-player-action pm-audio-action"
                                Classes.is-muted="{Binding VideoPlayer.IsMuted}"
                                Command="{Binding VideoPlayer.ToggleMuteCommand}"
                                IsEnabled="{Binding VideoPlayer.CanAdjustVolume}"
                                ToolTip.Tip="{Binding VideoPlayer.ToggleMuteText}">
                            <Viewbox Width="14"
                                     Height="12"
                                     Stretch="Uniform"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Grid Width="14"
                                      Height="12">
                                    <Grid Classes="pm-icon-unmuted"
                                          Width="14"
                                          Height="12"
                                          ColumnDefinitions="9,5">
                                        <Path Classes="pm-control-icon"
                                              Grid.Column="0"
                                              Data="M 1 4.5 H 4.25 L 7.5 2 V 10 L 4.25 7.5 H 1 Z"/>
                                    </Grid>
                                    <Grid Classes="pm-icon-muted"
                                          Width="14"
                                          Height="12"
                                          ColumnDefinitions="9,5">
                                        <Path Classes="pm-control-icon"
                                              Grid.Column="0"
                                              Data="M 1 4.5 H 4.25 L 7.5 2 V 10 L 4.25 7.5 H 1 Z"/>
                                        <Path Grid.Column="1"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="0,-0.6,0,0"
                                              Data="M 1.5 3.2 L 4.3 6 M 4.3 3.2 L 1.5 6"
                                              Stroke="{DynamicResource PmSectionTitleForeground}"
                                              StrokeThickness="1.1"
                                              StrokeLineCap="Round"
                                              Fill="Transparent"/>
                                    </Grid>
                                </Grid>
                            </Viewbox>
                        </Button>

                        <Slider Classes="pm-audio-slider"
                                Minimum="0"
                                Maximum="100"
                                Value="{Binding VideoPlayer.VolumePercent}"
                                IsEnabled="{Binding VideoPlayer.CanAdjustVolume}"
                                VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
