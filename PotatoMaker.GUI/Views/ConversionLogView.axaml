<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PotatoMaker.GUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="760" d:DesignHeight="220"
             x:Class="PotatoMaker.GUI.Views.ConversionLogView"
             x:DataType="vm:ConversionLogViewModel">

    <Design.DataContext>
        <vm:ConversionLogViewModel/>
    </Design.DataContext>

    <Border Classes="pm-card"
            Padding="10">
        <Grid RowDefinitions="Auto,Auto,*"
              RowSpacing="6">
            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
                <TextBlock Grid.Column="0"
                           Text="Console"
                           Classes="pm-section-title"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding ProgressLabel}"
                           HorizontalAlignment="Right"
                           Classes="pm-muted"/>
            </Grid>

            <Grid Grid.Row="1"
                  ColumnDefinitions="*,Auto"
                  IsVisible="{Binding IsProcessing}"
                  ColumnSpacing="8">
                <ProgressBar Grid.Column="0"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding ProgressPercent}"
                             Height="7"
                             VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding ProgressPercent, StringFormat={}{0}%}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>
            </Grid>

            <Border Grid.Row="2"
                    Background="{DynamicResource PmInsetBackground}"
                    BorderBrush="{DynamicResource PmInsetBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              x:Name="LogScroller">
                    <ItemsControl ItemsSource="{Binding LogLines}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontFamily="Cascadia Mono,Consolas,Menlo,monospace"
                                           FontSize="11.5"
                                           Margin="0,0,0,2"
                                           TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</UserControl>
