<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PotatoMaker.GUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="920" d:DesignHeight="720"
             x:Class="PotatoMaker.GUI.Views.HelpView"
             x:DataType="vm:HelpViewModel">

    <Design.DataContext>
        <vm:HelpViewModel/>
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="TextBlock.pm-help-title">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="{DynamicResource PmHeadingForeground}"/>
        </Style>

        <Style Selector="Button.pm-help-link">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="MinWidth" Value="110"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12"
                    Margin="0,0,0,12">
            <Border Classes="pm-card"
                    Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding Title}"
                               Classes="pm-help-title"/>
                    <TextBlock Text="{Binding IntroText}"
                               Classes="pm-muted"
                               TextWrapping="Wrap"/>

                    <ItemsControl ItemsSource="{Binding Links}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:HelpActionLink">
                                <Border Classes="pm-inset"
                                        Margin="0,4,0,0"
                                        Padding="12,10">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="12">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding Title}"
                                                       Classes="pm-section-title"/>
                                            <TextBlock Text="{Binding Description}"
                                                       Classes="pm-muted"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Content="{Binding ButtonText}"
                                                Classes="pm-help-link"
                                                VerticalAlignment="Center"
                                                Tag="{Binding Url}"
                                                Click="OnOpenLinkClick"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Classes="pm-card"
                    Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="About"
                               Classes="pm-section-title"/>
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="12"
                          RowDefinitions="Auto,Auto,Auto"
                          RowSpacing="6">
                        <TextBlock Text="Version"
                                   FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding VersionText}"
                                   Classes="pm-muted"/>

                        <TextBlock Grid.Row="1"
                                   Text="Copyright"
                                   FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Text="{Binding CopyrightText}"
                                   Classes="pm-muted"
                                   TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="2"
                                   Text="About"
                                   FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Text="PotatoMaker is a local video compression tool."
                                   Classes="pm-muted"
                                   TextWrapping="Wrap"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
