<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PotatoMaker.GUI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1180" d:DesignHeight="780"
        x:Class="PotatoMaker.GUI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/potato.ico"
        Title="PotatoMaker"
        Width="1180"
        Height="780"
        MinWidth="1020"
        MinHeight="700"
        CanResize="True">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid Margin="12"
          ColumnDefinitions="Auto,*"
          ColumnSpacing="14">
        <Border Grid.Column="0"
                x:Name="NavigationPane"
                Classes="pm-nav-surface"
                Width="72"
                Padding="10">
            <Grid RowDefinitions="Auto,Auto,*,Auto"
                  RowSpacing="14">
                <TextBlock Text="🥔"
                           Classes="pm-nav-brand"/>

                <StackPanel Grid.Row="1"
                            Spacing="8">
                    <Button Classes="pm-nav-button"
                            Classes.pm-nav-active="{Binding IsMainViewSelected}"
                            Command="{Binding ShowMainViewCommand}"
                            ToolTip.Tip="Main">
                        <TextBlock Text="&#xE80F;"
                                   Classes="pm-nav-icon"/>
                    </Button>

                    <Button Classes="pm-nav-button"
                            Classes.pm-nav-active="{Binding IsSettingsViewSelected}"
                            Command="{Binding ShowSettingsViewCommand}"
                            ToolTip.Tip="Settings">
                        <TextBlock Text="&#xE713;"
                                   Classes="pm-nav-icon"/>
                    </Button>

                    <Button Classes="pm-nav-button"
                            Classes.pm-nav-active="{Binding IsHelpViewSelected}"
                            Command="{Binding ShowHelpViewCommand}"
                            ToolTip.Tip="Help">
                        <TextBlock Text="&#xE897;"
                                   Classes="pm-nav-icon"/>
                    </Button>
                </StackPanel>

                <Border Grid.Row="3"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        VerticalAlignment="Bottom">
                    <TextBlock Text="{Binding VersionText}"
                               Classes="pm-sidebar-version"/>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <ContentControl Content="{Binding Workspace}"
                            IsVisible="{Binding IsMainViewSelected}"/>
            <ContentControl Content="{Binding Settings}"
                            IsVisible="{Binding IsSettingsViewSelected}"/>
            <ContentControl Content="{Binding Help}"
                            IsVisible="{Binding IsHelpViewSelected}"/>
        </Grid>
    </Grid>
</Window>
