<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PotatoMaker.GUI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1180" d:DesignHeight="700"
        x:Class="PotatoMaker.GUI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/potato.ico"
        Title="PotatoMaker"
        Width="1180"
        Height="700"
        MinWidth="1020"
        MinHeight="700"
        CanResize="True">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

        <Grid Margin="12"
              ColumnDefinitions="Auto,*"
              ColumnSpacing="14">
            <Border Grid.Column="0"
                    x:Name="NavigationPane"
                    Classes="pm-nav-surface"
                    Width="72"
                    Padding="10">
                <Grid RowDefinitions="Auto,Auto,*,Auto"
                      RowSpacing="14">
                    <StackPanel Grid.Row="1"
                                Spacing="8">
                        <Button Classes="pm-nav-button"
                                Classes.pm-nav-active="{Binding IsMainViewSelected}"
                                Command="{Binding ShowMainViewCommand}"
                                ToolTip.Tip="Main">
                            <TextBlock Text="&#xE80F;"
                                       Classes="pm-nav-icon"/>
                        </Button>

                        <Button x:Name="RecentVideosButton"
                                Classes="pm-nav-button"
                                Classes.pm-nav-active="{Binding IsRecentVideosPanelOpen}"
                                Command="{Binding ToggleRecentVideosPanelCommand}"
                                ToolTip.Tip="Recent videos">
                            <TextBlock Text="&#xE714;"
                                       Classes="pm-nav-icon"/>
                        </Button>

                        <Button Classes="pm-nav-button"
                                Classes.pm-nav-active="{Binding IsSettingsViewSelected}"
                                Command="{Binding ShowSettingsViewCommand}"
                                ToolTip.Tip="Settings">
                            <Grid Width="46"
                                  Height="46">
                                <TextBlock Text="&#xE713;"
                                           Classes="pm-nav-icon"/>
                                <Border Classes="pm-update-dot"
                                        IsVisible="{Binding IsUpdateBadgeVisible}"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,5,5,0"/>
                            </Grid>
                        </Button>

                        <Button Classes="pm-nav-button"
                                Classes.pm-nav-active="{Binding IsHelpViewSelected}"
                                Command="{Binding ShowHelpViewCommand}"
                                ToolTip.Tip="Help">
                            <TextBlock Text="&#xE897;"
                                       Classes="pm-nav-icon"/>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Row="3"
                                Spacing="10"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Bottom">
                        <Border Classes="pm-sidebar-version"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Bottom">
                            <TextBlock Text="{Binding VersionText}"
                                       Classes="pm-sidebar-version-text"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <ContentControl Content="{Binding Workspace}"
                                IsVisible="{Binding IsMainViewSelected}"/>
                <ContentControl Content="{Binding Settings}"
                                IsVisible="{Binding IsSettingsViewSelected}"/>
                <ContentControl Content="{Binding Help}"
                                IsVisible="{Binding IsHelpViewSelected}"/>
            </Grid>

        <Popup x:Name="RecentVideosPopup"
               IsOpen="{Binding IsRecentVideosPanelOpen, Mode=TwoWay}"
               PlacementTarget="{Binding #RecentVideosButton}"
               OverlayInputPassThroughElement="{Binding #NavigationPane}"
               Placement="RightEdgeAlignedTop"
               HorizontalOffset="12"
               VerticalOffset="0"
               IsLightDismissEnabled="True"
               OverlayDismissEventPassThrough="True"
               Topmost="True"
               Closed="OnRecentVideosPopupClosed">
            <Border Classes="pm-card pm-recent-panel"
                    Width="286"
                    Padding="12">
                <StackPanel Spacing="10">
                    <StackPanel Spacing="3">
                        <TextBlock Text="Recent videos"
                                   Classes="pm-section-title"/>
                        <TextBlock Text="{Binding RecentVideosDirectory}"
                                   Classes="pm-caption"
                                   MaxLines="1"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <Border Classes="pm-inset"
                            IsVisible="{Binding IsRecentVideosEmpty}">
                        <TextBlock Text="No recent supported videos found."
                                   Classes="pm-caption"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <ItemsControl ItemsSource="{Binding RecentVideos}"
                                  IsVisible="{Binding HasRecentVideos}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:RecentVideoItemViewModel">
                                <Button Classes="pm-recent-item"
                                        Command="{Binding SelectCommand}"
                                        HorizontalAlignment="Stretch"
                                        ToolTip.Tip="{Binding FullPath}">
                                    <Grid ColumnDefinitions="64,*"
                                          ColumnSpacing="10">
                                        <Border Classes="pm-recent-thumbnail"
                                                Width="64"
                                                Height="36">
                                            <Grid>
                                                <Image Source="{Binding Thumbnail}"
                                                       Classes="pm-recent-thumbnail-image"
                                                       IsVisible="{Binding HasThumbnail}"/>
                                                <TextBlock Text="&#xE714;"
                                                           Classes="pm-recent-thumbnail-placeholder"
                                                           IsVisible="{Binding IsThumbnailMissing}"/>
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Column="1"
                                                    Spacing="2"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FileName}"
                                                       Classes="pm-recent-item-title"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding ModifiedText}"
                                                       Classes="pm-caption"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
