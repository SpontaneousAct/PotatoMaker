<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PotatoMaker.GUI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="820" d:DesignHeight="680"
        x:Class="PotatoMaker.GUI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="PotatoMaker"
        Width="960"
        Height="680"
        CanResize="False">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid Margin="14"
          RowDefinitions="Auto,Auto,*"
          RowSpacing="10">
        <Border Grid.Row="0"
                Classes="pm-card pm-hero"
                Padding="10,8">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Spacing="10"
                            VerticalAlignment="Center">
                    <ToggleSwitch IsChecked="{Binding IsDarkMode}"
                                  OnContent="Dark"
                                  OffContent="Light"/>
                    <Border Padding="8,4"
                            CornerRadius="8"
                            Background="{DynamicResource PmInsetBackground}"
                            BorderBrush="{DynamicResource PmInsetBorderBrush}"
                            BorderThickness="1">
                        <TextBlock Text="{Binding VersionText}"
                                   Opacity="0.8"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            Spacing="10">
                    <TextBlock Text="PotatoMaker"
                               Classes="pm-heading"
                               FontSize="22"/>
                    <TextBlock Text="Discord-ready AV1 compression"
                               Classes="pm-muted"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1"
              ColumnDefinitions="2*,*"
              ColumnSpacing="10">
            <StackPanel Grid.Column="0"
                        Spacing="10">
                <ContentControl Content="{Binding FileInput}"/>
                <ContentControl Content="{Binding VideoSummary}"/>
            </StackPanel>

            <Grid Grid.Column="1"
                  RowDefinitions="Auto,*"
                  RowSpacing="10"
                  VerticalAlignment="Stretch">
                <ContentControl Grid.Row="0"
                                Content="{Binding OutputSettings}"/>
                <Button Grid.Row="1"
                        Content="Start Compression"
                        Command="{Binding StartEncodeCommand}"
                        MinHeight="38"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Stretch"
                        Classes="pm-primary"/>
            </Grid>
        </Grid>

        <ContentControl Grid.Row="2"
                        Content="{Binding ConversionLog}"/>
    </Grid>
</Window>
