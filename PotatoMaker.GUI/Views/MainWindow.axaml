<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PotatoMaker.GUI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="860" d:DesignHeight="560"
        x:Class="PotatoMaker.GUI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="PotatoMaker"
        Width="860"
        Height="560"
        MinWidth="860"
        MaxWidth="860"
        MinHeight="560"
        MaxHeight="560"
        CanResize="False">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid Margin="10"
          RowDefinitions="Auto,*"
          RowSpacing="8">
        <Border Grid.Row="0"
                Classes="pm-card pm-hero"
                Padding="10,7">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="10">
                <StackPanel Grid.Column="0"
                            Spacing="0"
                            VerticalAlignment="Center">
                    <TextBlock Text="PotatoMaker"
                               Classes="pm-heading"/>
                    <TextBlock Text="Discord-ready AV1 compression"
                               Classes="pm-caption"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <ToggleSwitch IsChecked="{Binding IsDarkMode}"
                                  OnContent="Dark"
                                  OffContent="Light"/>
                    <Border Classes="pm-inset"
                            Padding="7,3">
                        <TextBlock Text="{Binding VersionText}"
                                   Classes="pm-caption"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              ColumnDefinitions="1.65*,*"
              ColumnSpacing="8">
            <Grid Grid.Column="0"
                  RowDefinitions="Auto,*"
                  RowSpacing="8">
                <ContentControl Grid.Row="0"
                                Content="{Binding FileInput}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top"/>

                <ContentControl Grid.Row="1"
                                Content="{Binding ConversionLog}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"/>
            </Grid>

            <Grid Grid.Column="1"
                  RowDefinitions="*,Auto,Auto"
                  RowSpacing="8">
                <ContentControl Grid.Row="0"
                                Content="{Binding VideoSummary}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"/>

                <ContentControl Grid.Row="1"
                                Content="{Binding OutputSettings}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top"/>

                <Button Grid.Row="2"
                        Content="Start Compression"
                        Command="{Binding StartEncodeCommand}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Classes="pm-primary"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
