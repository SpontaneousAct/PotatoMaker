<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PotatoMaker.GUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="920" d:DesignHeight="720"
             x:Class="PotatoMaker.GUI.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12">
            <Border Classes="pm-card pm-settings-section"
                    Padding="16">
                <StackPanel Spacing="14">
                    <TextBlock Text="Appearance"
                               Classes="pm-section-title"/>

                    <Grid Classes="pm-settings-row"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="16">
                        <StackPanel Spacing="1">
                            <TextBlock Text="Theme"
                                       Classes="pm-settings-label"/>
                            <TextBlock Text="Switch between light and dark themes."
                                       Classes="pm-caption"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding IsDarkMode}"
                                      OnContent="Dark"
                                      OffContent="Light"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Classes="pm-card pm-settings-section"
                    Padding="16">
                <StackPanel Spacing="14">
                    <TextBlock Text="Encoding Defaults"
                               Classes="pm-section-title"/>

                    <Grid Classes="pm-settings-row"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="16">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Prefer NVIDIA NVENC AV1"
                                       Classes="pm-settings-label"/>
                            <TextBlock Text="Use the GPU encoder by default when this machine supports AV1 NVENC."
                                       Classes="pm-caption"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding OutputSettings.NvencSupportSummary}"
                                       Classes="pm-caption"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding OutputSettings.UseNvencEncoder}"
                                      IsEnabled="{Binding OutputSettings.CanUseNvenc}"
                                      OnContent="Enabled"
                                      OffContent="Off"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Classes="pm-settings-row"
                          ColumnDefinitions="*,220"
                          ColumnSpacing="16">
                        <StackPanel Spacing="2">
                            <TextBlock Text="CPU preset"
                                       Classes="pm-settings-label"/>
                            <TextBlock Text="Controls CPU encode speed when NVENC is unavailable or turned off."
                                       Classes="pm-caption"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding OutputSettings.CpuEncodePresetOptions}"
                                  SelectedItem="{Binding OutputSettings.SelectedCpuEncodePreset}"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Classes="pm-card pm-settings-section"
                    Padding="16">
                <StackPanel Spacing="14">
                    <TextBlock Text="Output Naming"
                               Classes="pm-section-title"/>

                    <Grid Classes="pm-settings-row"
                          ColumnDefinitions="*,220"
                          ColumnSpacing="16">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Filename prefix"
                                       Classes="pm-settings-label"/>
                            <TextBlock Text="Added before the source file name for every encoded output."
                                       Classes="pm-caption"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <TextBox Grid.Column="1"
                                 Text="{Binding OutputSettings.OutputNamePrefix}"
                                 Watermark="Optional"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Classes="pm-settings-row"
                          ColumnDefinitions="*,220"
                          ColumnSpacing="16">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Filename suffix"
                                       Classes="pm-settings-label"/>
                            <TextBlock Text="Added after the source file name. Split outputs still append part numbers after this suffix."
                                       Classes="pm-caption"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <TextBox Grid.Column="1"
                                 Text="{Binding OutputSettings.OutputNameSuffix}"
                                 Watermark="_discord"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Center"/>
                    </Grid>

                    <Border Classes="pm-inset"
                            Padding="12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Preview"
                                       Classes="pm-settings-label"/>
                            <TextBlock Text="{Binding OutputSettings.OutputFileNamePreview}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
